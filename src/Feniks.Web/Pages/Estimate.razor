            return;
        }

        try
        {
            isSavingEdit = true;
            StateHasChanged();

            var update = new
            {
                Id = estimate?.Id ?? 0,
                Name = editName,
                Description = editDescription,
                Status = editStatus,
                ManagerName = editManagerName,
                ManagerEmail = editManagerEmail,
                ConstructionObjectId = estimate?.ConstructionObjectId ?? 0,
                TotalCost = estimate?.TotalCost ?? 0,
                CustomerPrice = estimate?.CustomerPrice ?? 0
            };

            var response = await Http.PutAsJsonAsync($"http://localhost:5050/api/Estimates/{Id}", update);

            if (response.IsSuccessStatusCode)
            {
                if (estimate != null)
                {
                    estimate.Name = editName;
                    estimate.Description = editDescription;
                    estimate.Status = editStatus;
                    estimate.ManagerName = editManagerName;
                    estimate.ManagerEmail = editManagerEmail;
