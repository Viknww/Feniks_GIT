    private async Task ConfirmDeleteStage()
    {
        if (stageToDelete == null) return;

        try
        {
            isSaving = true;
            StateHasChanged();

            Console.WriteLine($"Удаление этапа ID: {stageToDelete.Id}");

            var stageItems = items.Where(i => i.StageId == stageToDelete.Id).ToList();
            Console.WriteLine($"Позиций для удаления: {stageItems.Count}");
            
            foreach (var item in stageItems)
            {
                await Http.DeleteAsync($"http://localhost:5050/api/EstimateItems/{item.Id}");
            }

            var stageGroups = groups.Where(g => g.StageId == stageToDelete.Id).ToList();
            Console.WriteLine($"Групп для удаления: {stageGroups.Count}");
            
            foreach (var group in stageGroups)
            {
                await Http.DeleteAsync($"http://localhost:5050/api/EstimateItemGroups/{group.Id}");
            }

            var response = await Http.DeleteAsync($"http://localhost:5050/api/EstimateStages/{stageToDelete.Id}");

            if (response.IsSuccessStatusCode)
            {
                Console.WriteLine($"✅ Этап {stageToDelete.Id} удален из БД");
                
                await LoadData();
                selectedItems.Clear();
                CloseDeleteStageModal();
                await NotifyChanges();
                
                await JS.InvokeVoidAsync("alert", $"✅ Этап '{stageToDelete.Name}' удален");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка удаления этапа: {error}");
                await JS.InvokeVoidAsync("alert", $"Ошибка при удалении этапа: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

