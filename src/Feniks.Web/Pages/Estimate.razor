    private decimal GetGroupTotal(int groupId)
    {
        return items.Where(i => i.GroupId == groupId).Sum(i => i.Price * i.Quantity);
    }

    private decimal GetGroupCustomerTotal(int groupId)
    {
        return items.Where(i => i.GroupId == groupId).Sum(i => i.CustomerPrice * i.Quantity);
    }

    private decimal GetGroupProfit(int groupId)
    {
        return GetGroupCustomerTotal(groupId) - GetGroupTotal(groupId);
    }

