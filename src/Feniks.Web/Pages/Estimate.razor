    private void ShowCopyMoveModal(string target, string mode)
    {
        showCopyDropdown = false;
        showMoveDropdown = false;
        
        copyMoveMode = mode;
        copyMoveTarget = target;
        
        currentStageId = null;
        currentGroupId = null;
        
        if (selectedItems.Any())
        {
            var firstItem = items.First(i => selectedItems.Contains(i.Id));
            if (firstItem != null)
            {
                currentStageId = firstItem.StageId;
                currentGroupId = firstItem.GroupId;
                Console.WriteLine($"ShowCopyMoveModal: Текущий этап установлен: {currentStageId}, текущая группа: {currentGroupId}");
            }
        }

        if (target == "same" && mode == "copy")
        {
            _ = ExecuteCopyMoveSame();
            return;
        }

        string action = mode == "copy" ? "Копирование" : "Перемещение";
        string targetText = target switch
        {
            "group" => "в группу",
            "stage" => "в этап",
            _ => ""
        };
        copyMoveTitle = $"{action} позиций ({selectedItems.Count} шт.) {targetText}";

        selectedTargetStageId = null;
        selectedTargetGroupId = null;
        isCreatingNewGroup = false;
        newGroupName = "";
        showCopyMoveModal = true;
        
        Console.WriteLine($"ShowCopyMoveModal: Модальное окно открыто, currentStageId={currentStageId}");
        StateHasChanged();
    }

    private async Task ExecuteCopyMoveSame()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var itemsToProcess = items.Where(i => selectedItems.Contains(i.Id)).ToList();

            foreach (var item in itemsToProcess)
            {
                var newItem = new
                {
                    EstimateId = Id,
                    GroupId = item.GroupId,
                    StageId = item.StageId,
                    Name = $"{item.Name} (копия)",
                    Unit = item.Unit,
                    Quantity = item.Quantity,
                    Price = item.Price,
                    Markup = item.Markup,
                    Type = item.Type,
                    OrderIndex = items.Count,
                    CustomerPrice = item.CustomerPrice
                };
                await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", newItem);
            }

            await LoadData();
            selectedItems.Clear();
            await NotifyChanges();
            
            await JS.InvokeVoidAsync("alert", $"✅ {itemsToProcess.Count} позиций скопировано");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при копировании: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

