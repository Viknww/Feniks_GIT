@page "/estimate/{id:int}"
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using Feniks.Shared.Models
@using Feniks.Web.Services
@using SharedEstimate = Feniks.Shared.Models.Estimate
@using SharedConstructionObject = Feniks.Shared.Models.ConstructionObject
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject NotificationService NotificationService
@inject DataSyncService DataSyncService

<link href="css/estimate.css" rel="stylesheet" />

<div class="estimate-page" @onclick="CloseAllDropdowns">
    <!-- Хлебные крошки -->
    <div class="breadcrumbs mb-3">
        <a href="/">Главная</a> <span class="mx-2">›</span>
        <a href="/objects">Объекты</a> <span class="mx-2">›</span>
        <span>@(estimate?.Name ?? "")</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка сметы...</p>
        </div>
    }
    else if (estimate == null)
    {
        <div class="alert alert-danger">
            Смета не найдена
        </div>
    }
    else
    {
        <!-- Индикатор сохранения -->
        @if (isSaving)
        {
            <div class="position-fixed top-0 end-0 m-3 p-2 bg-success text-white rounded">
                <i class="bi bi-check-circle me-1"></i>Сохранено
            </div>
        }

        <!-- Заголовок сметы -->
        <div class="estimate-header bg-white rounded-3 shadow-sm p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap" style="gap: 1rem;">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <h1 class="h3 mb-0">@estimate.Name</h1>
                        <span class="h3 mb-0 text-success fw-bold">@FormatNumber(customerTotal) ₽</span>
                    </div>
                    <div class="d-flex gap-4 text-muted flex-wrap">
                        <span><i class="bi bi-building me-1"></i> Объект: @objectName</span>
                        <span><i class="bi bi-person me-1"></i> Менеджеры: @estimate.ManagerName, @estimate.ManagerEmail</span>
                    </div>
                    <div class="d-flex gap-3 mt-2 align-items-center">
                        <!-- Кнопка статуса с Blazor-совместимым dropdown -->
                        <div class="dropdown" @onclick:stopPropagation="true" style="position: relative; display: inline-block;">
                            <button class="btn btn-sm status-btn @GetStatusClass(estimate.Status)" 
                                    @onclick="ToggleStatusDropdown" 
                                    style="min-width: 100px;">
                                @estimate.Status <i class="bi bi-chevron-down ms-1 small"></i>
                            </button>
                            
                            @if (showStatusDropdown)
                            {
                                <div class="dropdown-menu show" style="position: absolute; top: 100%; left: 0; z-index: 1000; display: block; min-width: 160px;">
                                    <button class="dropdown-item" @onclick='() => ChangeStatus("Черновик")'>Черновик</button>
                                    <button class="dropdown-item" @onclick='() => ChangeStatus("Согласование")'>Согласование</button>
                                    <button class="dropdown-item" @onclick='() => ChangeStatus("В работе")'>В работе</button>
                                    <button class="dropdown-item" @onclick='() => ChangeStatus("Завершена")'>Завершена</button>
                                </div>
                            }
                        </div>
                        
                        <!-- Кнопка для открытия модального окна редактирования -->
                        <button class="btn btn-link text-muted p-0 border-0" @onclick="OpenEditModal" style="text-decoration: none;">
                            <i class="bi bi-pencil me-1"></i>Режим правки
                        </button>
                        
                        <span class="text-muted"><i class="bi bi-lock me-1"></i>Фиксация цены заказчика</span>
                    </div>
                </div>
               <div class="d-flex gap-2">
    <button class="btn btn-sm btn-outline-secondary">Экспорт</button>
    <button class="btn btn-sm btn-outline-secondary">Обновить цены</button>
    <button class="btn btn-sm btn-outline-secondary">Создать копию</button>
    
    <!-- Кнопка печати с Blazor-совместимым dropdown -->
    <div style="position: relative; display: inline-block;" @onclick:stopPropagation="true">
        <button class="btn btn-sm btn-outline-secondary" @onclick="TogglePrintDropdown" style="display: inline-flex; align-items: center;">
            <i class="bi bi-printer me-1"></i>Печать
            <i class="bi bi-chevron-down ms-1 small"></i>
        </button>
        
        @if (showPrintDropdown)
        {
            <div style="position: absolute; top: 35px; right: 0; z-index: 1000; background: white; border: 1px solid rgba(0,0,0,0.15); border-radius: 4px; box-shadow: 0 6px 12px rgba(0,0,0,0.175); min-width: 200px; padding: 8px 0;" @onclick:stopPropagation="true">
                <button class="dropdown-item w-100 text-start" @onclick='() => PrintDocument("estimate")' style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none;">
                    <i class="bi bi-file-text me-2"></i>Смета
                </button>
                <button class="dropdown-item w-100 text-start" @onclick='() => PrintDocument("ks2")' style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none;">
                    <i class="bi bi-file-earmark-check me-2"></i>КС-2 (Акт работ)
                </button>
                <button class="dropdown-item w-100 text-start" @onclick='() => PrintDocument("ks3")' style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none;">
                    <i class="bi bi-file-earmark-spreadsheet me-2"></i>КС-3 (Справка)
                </button>
                <div style="height: 1px; background-color: #e9ecef; margin: 8px 0;"></div>
                <button class="dropdown-item w-100 text-start" @onclick='() => PrintDocument("invoice")' style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none;">
                    <i class="bi bi-receipt me-2"></i>Счет на оплату
                </button>
            </div>
        }
    </div>
    
    <button class="btn btn-sm btn-outline-secondary">Архивировать</button>
</div>
            </div>
        </div>

        <!-- Общий сворачиваемый блок стоимости -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light py-2" @onclick="ToggleCostSection" style="cursor: pointer;">
                <div class="d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-2">
                        <span class="btn-collapse">
                            <i class="bi @(expandedCostSection ? "bi-chevron-down" : "bi-chevron-right")"></i>
                        </span>
                        <span class="fw-bold">Финансовые показатели</span>
                    </div>
                    <div class="d-flex gap-4">
                        <span class="text-primary fw-bold">Себестоимость: @FormatNumber(totalCost) ₽</span>
                        <span class="fw-bold" style="color: #b45f06;">Прибыль: @FormatNumber(profitTotal) ₽</span>
                        <span class="text-success fw-bold">Для заказчика: @FormatNumber(customerTotal) ₽</span>
                    </div>
                </div>
            </div>
            
            @if (expandedCostSection)
            {
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-3">Себестоимость по типам</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Работы</span>
                                        <span class="fw-bold">@FormatNumber(workCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Материалы</span>
                                        <span class="fw-bold">@FormatNumber(materialCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Механизмы</span>
                                        <span class="fw-bold">@FormatNumber(machineryCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Доставка</span>
                                        <span class="fw-bold">@FormatNumber(deliveryCost) ₽</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-3">Прибыль по типам</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Работы</span>
                                        <span class="fw-bold" style="color: #b45f06;">@FormatNumber(profitWork) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Материалы</span>
                                        <span class="fw-bold" style="color: #b45f06;">@FormatNumber(profitMaterial) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Механизмы</span>
                                        <span class="fw-bold" style="color: #b45f06;">@FormatNumber(profitMachineryCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Доставка</span>
                                        <span class="fw-bold" style="color: #b45f06;">@FormatNumber(profitDelivery) ₽</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card shadow-sm">
                                <div class="card-body">
                                    <h6 class="text-muted mb-3">Для заказчика по типам</h6>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Работы</span>
                                        <span class="fw-bold text-success">@FormatNumber(customerWorkCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Материалы</span>
                                        <span class="fw-bold text-success">@FormatNumber(customerMaterialCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2">
                                        <span>Механизмы</span>
                                        <span class="fw-bold text-success">@FormatNumber(customerMachineryCost) ₽</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Доставка</span>
                                        <span class="fw-bold text-success">@FormatNumber(customerDeliveryCost) ₽</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Этапы сметы -->
        <div class="stages-container">
            @if (!stages.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-layers fs-1 d-block mb-3"></i>
                    <p>Нет этапов в смете</p>
                    <button class="btn btn-outline-primary" @onclick="AddStage">
                        Добавить первый этап
                    </button>
                </div>
            }
            else
            {
                @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                {
                    <div class="stage-card card shadow-sm mb-4">
                        <div class="card-header bg-light py-2" @onclick="() => ToggleStage(stage.Id)">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2 flex-grow-1">
                                    <span class="btn-collapse">
                                        <i class="bi @(GetStageExpanded(stage.Id) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                    </span>
                                    <span class="badge bg-secondary me-1">@(stages.OrderBy(s => s.OrderIndex).ToList().IndexOf(stage) + 1)</span>
                                    
                                    @if (editingStageId == stage.Id)
                                    {
                                        <input type="text" class="form-control form-control-sm" @bind="editingStageName" 
                                               style="width: 300px;" @onkeydown="(e) => HandleStageEnter(e, stage)" 
                                               @onclick:stopPropagation="true" />
                                        <button class="btn btn-sm btn-success" @onclick="() => SaveStage(stage)" @onclick:stopPropagation="true">✓</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditStage" @onclick:stopPropagation="true">✗</button>
                                    }
                                    else
                                    {
                                        <h6 class="mb-0 fw-bold">@stage.Name</h6>
                                        <button class="btn btn-sm btn-link py-0" @onclick="() => EditStage(stage)" @onclick:stopPropagation="true">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-link py-0 text-danger" @onclick="() => ShowDeleteStageModal(stage)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                                <div class="d-flex align-items-center gap-3" @onclick:stopPropagation="true">
                                    <span class="badge bg-light text-dark"><span class="me-1">💰</span>@FormatNumber(GetStageTotal(stage.Id)) ₽</span>
                                    <span class="badge" style="background-color: #ffe0b5; color: #b45f06;"><span class="me-1">📈</span>@FormatNumber(GetStageProfit(stage.Id)) ₽</span>
                                    <span class="badge bg-success text-white"><span class="me-1">📊</span>@FormatNumber(GetStageCustomerTotal(stage.Id)) ₽</span>
                                </div>
                            </div>
                        </div>

                        @if (GetStageExpanded(stage.Id))
                        {
                            <div class="card-body p-3">
                                <!-- Панель инструментов для этапа -->
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <button class="btn btn-primary btn-sm" @onclick="() => ShowAddItemDialog(stage.Id)">
                                        <i class="bi bi-plus-circle me-1"></i>+ позиция
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-download me-1"></i>Импорт данных
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-percent me-1"></i>% Наценки и скидки
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-book me-1"></i>Справочники
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-database me-1"></i>База расценок
                                    </button>
                                </div>

                                <!-- Таблица позиций -->
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover align-middle">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 30px"></th>
                                                <th style="width: 60px">№</th>
                                                <th style="width: 50px">Тип</th>
                                                <th>Позиция</th>
                                                <th style="width: 50px">Ед. изм.</th>
                                                <th style="width: 70px">Кол-во</th>
                                                <th style="width: 80px">Цена</th>
                                                <th style="width: 90px">Стоимость</th>
                                                <th style="width: 60px">Наценка %</th>
                                                <th style="width: 80px">Цена для заказчика</th>
                                                <th style="width: 90px">Стоимость для заказчика</th>
                                                <th style="width: 40px"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                var stageGroups = groups.Where(g => g.StageId == stage.Id).OrderBy(g => g.OrderIndex).ToList();
                                            }

                                            @foreach (var group in stageGroups)
                                            {
                                                <!-- Заголовок группы -->
                                                <tr class="table-secondary">
                                                    <td colspan="12" class="p-0">
                                                        <div class="d-flex align-items-center py-1 px-2" @onclick="() => ToggleGroup(group.Id)" style="cursor: pointer;">
                                                            <span class="btn-collapse me-2">
                                                                <i class="bi @(GetGroupExpanded(group.Id) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                                            </span>
                                                            <span class="badge bg-info me-2">
                                                                @(stages.OrderBy(s => s.OrderIndex).ToList().IndexOf(stage) + 1).@(stageGroups.IndexOf(group) + 1)
                                                            </span>
                                                            
                                                            @if (editingGroupId == group.Id)
                                                            {
                                                                <input type="text" class="form-control form-control-sm" @bind="editingGroupName" 
                                                                       style="width: 250px;" @onkeydown="(e) => HandleGroupEnter(e, group)" 
                                                                       @onclick:stopPropagation="true" />
                                                                <button class="btn btn-sm btn-success ms-2" @onclick="() => SaveGroup(group)" @onclick:stopPropagation="true">✓</button>
                                                                <button class="btn btn-sm btn-secondary ms-1" @onclick="CancelEditGroup" @onclick:stopPropagation="true">✗</button>
                                                            }
                                                            else
                                                            {
                                                                <span class="fw-bold me-2">@group.Name</span>
                                                                <button class="btn btn-sm btn-link py-0" @onclick="() => EditGroup(group)" @onclick:stopPropagation="true" title="Редактировать">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>
                                                                <button class="btn btn-sm btn-link py-0 text-danger" @onclick="() => DeleteGroup(group.Id)" @onclick:stopPropagation="true" title="Удалить группу">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            }
                                                            
                                                            <span class="ms-auto me-3">
                                                                <span class="badge bg-light text-dark me-2"><span class="me-1">💰</span>@FormatNumber(GetGroupTotal(group.Id)) ₽</span>
                                                                <span class="badge me-2" style="background-color: #ffe0b5; color: #b45f06;"><span class="me-1">📈</span>@FormatNumber(GetGroupProfit(group.Id)) ₽</span>
                                                                <span class="badge bg-success"><span class="me-1">📊</span>@FormatNumber(GetGroupCustomerTotal(group.Id)) ₽</span>
                                                            </span>
                                                        </div>
                                                    </td>
                                                </tr>

                                                @if (GetGroupExpanded(group.Id))
                                                {
                                                    var groupItems = items.Where(i => i.GroupId == group.Id).OrderBy(i => i.OrderIndex).ToList();
                                                    @foreach (var item in groupItems)
                                                    {
                                                        var total = item.Price * item.Quantity;
                                                        var customerTotal = item.CustomerPrice * item.Quantity;
                                                        <tr data-type="@item.Type" class="@(selectedItems.Contains(item.Id) ? "table-primary" : "")">
                                                            <td><input type="checkbox" @onchange="() => ToggleItemSelection(item.Id)" checked="@selectedItems.Contains(item.Id)" /></td>
                                                            <td>
                                                                @{
                                                                    int stageIdx = stages.OrderBy(s => s.OrderIndex).ToList().IndexOf(stage) + 1;
                                                                    int groupIdx = stageGroups.IndexOf(group) + 1;
                                                                    int itemIdx = groupItems.IndexOf(item) + 1;
                                                                }
                                                                @stageIdx.@groupIdx.@itemIdx
                                                            </td>
                                                            <td>
                                                                <select class="form-select form-select-sm type-field" @bind="item.Type" @bind:event="oninput" @onblur="() => OnTypeChanged(item)">
                                                                    <option value="P">P</option>
                                                                    <option value="M">M</option>
                                                                    <option value="X">X</option>
                                                                    <option value="D">D</option>
                                                                </select>
                                                            </td>
                                                            <td><input type="text" class="form-control form-control-sm" @bind="item.Name" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="text" class="form-control form-control-sm" @bind="item.Unit" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.Quantity" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.Price" @bind:event="oninput" @onblur="() => OnPriceChanged(item)" /></td>
                                                            <td class="fw-bold">@FormatNumber(total) ₽</td>
                                                            <td><input type="number" class="form-control form-control-sm markup-field" @bind="item.Markup" @bind:event="oninput" @onblur="() => OnMarkupChanged(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.CustomerPrice" @bind:event="oninput" @onblur="() => OnCustomerPriceChanged(item)" /></td>
                                                            <td class="fw-bold text-success">@FormatNumber(customerTotal) ₽</td>
                                                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)"><i class="bi bi-trash"></i></button></td>
                                                        </tr>
                                                    }
                                                }
                                            }

                                            <!-- ========== ПОЗИЦИИ БЕЗ ГРУППЫ ========== -->
                                            @{
                                                var ungroupedItems = items
                                                    .Where(i => i.GroupId == null && (i.StageId == stage.Id || i.StageId == null))
                                                    .OrderBy(i => i.OrderIndex)
                                                    .ToList();
                                            }
                                            @if (ungroupedItems.Any())
                                            {
                                                <tr class="table-secondary">
                                                    <td colspan="12" class="py-1 px-2">
                                                        <span class="fw-bold">Позиции без группы (@ungroupedItems.Count)</span>
                                                    </td>
                                                </tr>
                                                @foreach (var item in ungroupedItems)
                                                {
                                                    var total = item.Price * item.Quantity;
                                                    var customerTotal = item.CustomerPrice * item.Quantity;
                                                    <tr data-type="@item.Type" class="@(selectedItems.Contains(item.Id) ? "table-primary" : "")">
                                                        <td><input type="checkbox" @onchange="() => ToggleItemSelection(item.Id)" checked="@selectedItems.Contains(item.Id)" /></td>
                                                        <td>@(ungroupedItems.IndexOf(item) + 1)</td>
                                                        <td>
                                                            <select class="form-select form-select-sm type-field" @bind="item.Type" @bind:event="oninput" @onblur="() => OnTypeChanged(item)">
                                                                <option value="P">P</option>
                                                                <option value="M">M</option>
                                                                <option value="X">X</option>
                                                                <option value="D">D</option>
                                                            </select>
                                                        </td>
                                                        <td><input type="text" class="form-control form-control-sm" @bind="item.Name" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                        <td><input type="text" class="form-control form-control-sm" @bind="item.Unit" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.Quantity" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.Price" @bind:event="oninput" @onblur="() => OnPriceChanged(item)" /></td>
                                                        <td class="fw-bold">@FormatNumber(total) ₽</td>
                                                        <td><input type="number" class="form-control form-control-sm markup-field" @bind="item.Markup" @bind:event="oninput" @onblur="() => OnMarkupChanged(item)" /></td>
                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.CustomerPrice" @bind:event="oninput" @onblur="() => OnCustomerPriceChanged(item)" /></td>
                                                        <td class="fw-bold text-success">@FormatNumber(customerTotal) ₽</td>
                                                        <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)"><i class="bi bi-trash"></i></button></td>
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                }
                
                <!-- Кнопка добавления нового этапа -->
                <div class="text-center mt-4">
                    <button class="btn btn-outline-primary btn-lg" @onclick="AddStage">
                        <i class="bi bi-plus-circle me-2"></i>Добавить этап
                    </button>
                </div>
            }
        </div>

        <!-- Нижний колонтитул с выбранными позициями -->
        @if (selectedItems.Any())
        {
            <div class="card shadow-sm mt-4 position-sticky-bottom">
                <div class="card-body bg-light">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div>
                            <span class="fw-bold me-3">Выбрано позиций: @selectedItems.Count</span>
                            <span class="me-3"><span class="me-1">💰</span>Себестоимость: @FormatNumber(selectedSum) ₽</span>
                            <span class="me-3"><span class="me-1">📈</span>Прибыль: @FormatNumber(selectedProfit) ₽</span>
                            <span class="text-success"><span class="me-1">📊</span>Для заказчика: @FormatNumber(selectedCustomerSum) ₽</span>
                        </div>
                        <div class="d-flex gap-2">
                            <!-- Кнопка группирования -->
                            <button class="btn btn-sm btn-outline-success" @onclick="ShowGroupModal">
                                <i class="bi bi-folder-plus me-1"></i>Группировать
                            </button>

                            <!-- Кнопка Копировать -->
                            <button class="btn btn-sm btn-outline-primary" @onclick="ShowCopyOptions">
                                <i class="bi bi-files me-1"></i>Копировать
                            </button>

                            <!-- Кнопка Переместить -->
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowMoveOptions">
                                <i class="bi bi-folder-plus me-1"></i>Переместить
                            </button>

                            <!-- Кнопка Разгруппировать -->
                            @if (selectedItems.Any(i => items.First(x => x.Id == i).GroupId.HasValue))
                            {
                                <button class="btn btn-sm btn-outline-warning" @onclick="UngroupSelected">
                                    <i class="bi bi-folder-minus me-1"></i>Разгруппировать
                                </button>
                            }

                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">
                                <i class="bi bi-trash me-1"></i>Удалить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Диалог копирования/перемещения -->
        @if (showCopyMoveOptions)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@dialogTitle</h5>
                            <button type="button" class="btn-close" @onclick="CloseCopyMoveOptions"></button>
                        </div>
                        <div class="modal-body">
                            <!-- Предупреждение о разных группах/этапах -->
                            @if (showMixedItemsWarning)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    Выбраны позиции из разных групп или этапов
                                </div>
                            }

                            <!-- Выбор действия для копирования -->
                            @if (dialogMode == "copy")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Выберите действие:</label>
                                    <div class="d-flex flex-column gap-2">
                                        <button class="btn btn-outline-primary text-start" @onclick="() => StartSimpleCopy()">
                                            <i class="bi bi-files me-2"></i> Копировать (без изменения группы/этапа)
                                        </button>
                                        <button class="btn btn-outline-primary text-start" @onclick="() => StartCopyToGroup()">
                                            <i class="bi bi-folder me-2"></i> В группу
                                        </button>
                                        <button class="btn btn-outline-primary text-start" @onclick="() => StartCopyToStage()">
                                            <i class="bi bi-layers me-2"></i> В этап
                                        </button>
                                        <button class="btn btn-outline-primary text-start" @onclick="() => StartCopyToUngrouped()">
                                            <i class="bi bi-folder-minus me-2"></i> Без группы
                                        </button>
                                        <button class="btn btn-outline-secondary text-start" disabled>
                                            <i class="bi bi-file-earmark me-2"></i> В смету (скоро)
                                        </button>
                                    </div>
                                </div>
                            }

                            <!-- Выбор действия для перемещения -->
                            @if (dialogMode == "move")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Выберите действие:</label>
                                    <div class="d-flex flex-column gap-2">
                                        <button class="btn btn-outline-secondary text-start" @onclick="() => StartMoveToGroup()">
                                            <i class="bi bi-folder me-2"></i> В группу
                                        </button>
                                        <button class="btn btn-outline-secondary text-start" @onclick="() => StartMoveToStage()">
                                            <i class="bi bi-layers me-2"></i> В этап
                                        </button>
                                        <button class="btn btn-outline-secondary text-start" @onclick="() => StartMoveToUngrouped()">
                                            <i class="bi bi-folder-minus me-2"></i> Без группы
                                        </button>
                                        <button class="btn btn-outline-secondary text-start" disabled>
                                            <i class="bi bi-file-earmark me-2"></i> В смету (скоро)
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseCopyMoveOptions">Отмена</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно выбора группы/этапа -->
        @if (showTargetSelection)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">@targetSelectionTitle</h5>
                            <button type="button" class="btn-close" @onclick="CloseTargetSelection"></button>
                        </div>
                        <div class="modal-body">
                            <!-- Выбор этапа -->
                            @if (targetType == "stage")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Выберите этап:</label>
                                    <select class="form-select" @bind="selectedTargetStageId">
                                        <option value="">-- Выберите этап --</option>
                                        @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                                        {
                                            <option value="@stage.Id">@stage.Name</option>
                                        }
                                        <option value="-1" style="color: #0d6efd; font-weight: 500;">➕ Новый этап</option>
                                    </select>
                                </div>

                                @if (selectedTargetStageId == -1)
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Название нового этапа</label>
                                        <input type="text" class="form-control" @bind="newStageName" placeholder="Введите название этапа" />
                                    </div>
                                }
                            }

                            <!-- Выбор группы -->
                            @if (targetType == "group")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Выберите этап для группы:</label>
                                    <select class="form-select" @bind="selectedGroupStageId">
                                        <option value="">-- Выберите этап --</option>
                                        @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                                        {
                                            <option value="@stage.Id">@stage.Name</option>
                                        }
                                    </select>
                                </div>

                                @if (selectedGroupStageId.HasValue && selectedGroupStageId > 0)
                                {
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Выберите группу:</label>
                                        <select class="form-select" @bind="selectedTargetGroupId">
                                            <option value="">-- Без группы --</option>
                                            @{
                                                var availableGroups = groups.Where(g => g.StageId == selectedGroupStageId).OrderBy(g => g.Name).ToList();
                                            }
                                            @foreach (var group in availableGroups)
                                            {
                                                <option value="@group.Id">@group.Name</option>
                                            }
                                            <option value="-1" style="color: #0d6efd; font-weight: 500;">➕ Новая группа</option>
                                        </select>
                                    </div>

                                    @if (selectedTargetGroupId == -1)
                                    {
                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Название новой группы</label>
                                            <input type="text" class="form-control" @bind="newGroupName" placeholder="Введите название группы" />
                                        </div>
                                    }
                                }
                            }

                            <!-- Выбор "без группы" -->
                            @if (targetType == "ungrouped")
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Выберите этап для размещения:</label>
                                    <select class="form-select" @bind="selectedTargetStageId">
                                        <option value="">-- Выберите этап --</option>
                                        @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                                        {
                                            <option value="@stage.Id">@stage.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="alert alert-info">
                                    <i class="bi bi-info-circle me-2"></i>
                                    Позиции будут перемещены в выбранный этап без группы
                                </div>
                            }

                            <div class="alert alert-info mt-3">
                                <i class="bi bi-info-circle me-2"></i>
                                <strong>@selectedItems.Count</strong> позиций будут @(dialogMode == "copy" ? "скопированы" : "перемещены")
                                @if (targetType == "stage")
                                {
                                    if (selectedTargetStageId == -1 && !string.IsNullOrWhiteSpace(newStageName))
                                    {
                                        <span>в новый этап <strong>@newStageName</strong></span>
                                    }
                                    else if (selectedTargetStageId > 0)
                                    {
                                        var stage = stages.FirstOrDefault(s => s.Id == selectedTargetStageId);
                                        <span>в этап <strong>@stage?.Name</strong></span>
                                    }
                                }
                                @if (targetType == "group")
                                {
                                    if (selectedTargetGroupId == -1 && !string.IsNullOrWhiteSpace(newGroupName))
                                    {
                                        <span>в новую группу <strong>@newGroupName</strong></span>
                                    }
                                    else if (selectedTargetGroupId > 0)
                                    {
                                        var group = groups.FirstOrDefault(g => g.Id == selectedTargetGroupId);
                                        <span>в группу <strong>@group?.Name</strong></span>
                                    }
                                    else
                                    {
                                        <span>без группы</span>
                                    }
                                }
                                @if (targetType == "ungrouped")
                                {
                                    if (selectedTargetStageId > 0)
                                    {
                                        var stage = stages.FirstOrDefault(s => s.Id == selectedTargetStageId);
                                        <span>в этап <strong>@stage?.Name</strong> без группы</span>
                                    }
                                }
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseTargetSelection">Назад</button>
                            <button class="btn btn-primary" @onclick="ExecuteTargetAction" disabled="@isTargetSelectionInvalid">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                @(dialogMode == "copy" ? "Копировать" : "Переместить")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Диалог добавления позиции -->
        @if (showAddDialog)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">➕ Добавить позицию</h5>
                            <button type="button" class="btn-close" @onclick="CloseAddDialog"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label fw-bold">Наименование *</label>
                                    <input type="text" class="form-control" @bind="newItem.Name" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Тип</label>
                                    <select class="form-select" @bind="newItem.Type">
                                        <option value="P">P - Работы</option>
                                        <option value="M">M - Материалы</option>
                                        <option value="X">X - Механизмы</option>
                                        <option value="D">D - Доставка</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Ед. изм.</label>
                                    <input type="text" class="form-control" @bind="newItem.Unit" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Количество</label>
                                    <input type="number" class="form-control" @bind="newItem.Quantity" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Цена</label>
                                    <input type="number" class="form-control" @bind="newItem.Price" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Наценка, %</label>
                                    <input type="number" class="form-control" @bind="newItem.Markup" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-bold">Этап</label>
                                    <select class="form-select" @bind="newItem.StageId" @bind:event="onchange">
                                        <option value="">Выберите этап</option>
                                        @foreach (var stage in stages)
                                        {
                                            <option value="@stage.Id">@stage.Name</option>
                                        }
                                    </select>
                                    @if (newItem.StageId == null)
                                    {
                                        <small class="text-danger">Этап обязателен!</small>
                                    }
                                </div>
                                
                                <!-- Режим создания новой группы -->
                                @if (isCreatingNewGroupInAdd)
                                {
                                    <div class="col-md-8 mb-3">
                                        <label class="form-label fw-bold">Название новой группы</label>
                                        <input type="text" class="form-control" @bind="newGroupNameInAdd" placeholder="Введите название группы" />
                                    </div>
                                    <div class="col-md-4 mb-3 d-flex align-items-end">
                                        <button class="btn btn-sm btn-success" @onclick="CreateNewGroupInAdd" disabled="@string.IsNullOrWhiteSpace(newGroupNameInAdd)">
                                            <i class="bi bi-check-lg"></i> Создать
                                        </button>
                                        <button class="btn btn-sm btn-secondary ms-2" @onclick="CancelNewGroupInAdd">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-bold">Группа</label>
                                        <select class="form-select" @bind="newItem.GroupId">
                                            <option value="">Без группы</option>
                                            @{
                                                var availableGroups = new List<EstimateItemGroup>();
                                                if (newItem.StageId.HasValue)
                                                {
                                                    availableGroups = groups.Where(g => g.StageId == newItem.StageId).OrderBy(g => g.Name).ToList();
                                                }
                                            }
                                            @foreach (var group in availableGroups)
                                            {
                                                <option value="@group.Id">@group.Name</option>
                                            }
                                            @if (newItem.StageId.HasValue && availableGroups.Any())
                                            {
                                                <option value="-1" style="color: #0d6efd; font-weight: 500;">➕ Новая группа...</option>
                                            }
                                        </select>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseAddDialog">Отмена</button>
                            <button class="btn btn-primary" @onclick="AddItem" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Добавить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно для группирования -->
        @if (showGroupModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);" @onclick:stopPropagation="true">
                <div class="modal-dialog" @onclick:stopPropagation="true">
                    <div class="modal-content">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">📁 Создание группы</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseGroupModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Название новой группы *</label>
                                <input type="text" class="form-control" @bind="newGroupName" @bind:event="oninput" placeholder="Введите название группы" />
                                @if (string.IsNullOrWhiteSpace(newGroupName))
                                {
                                    <div class="text-danger small mt-1">Введите название группы</div>
                                }
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label fw-bold">Выберите этап *</label>
                                <select class="form-select" @bind="selectedGroupStageId" @bind:event="onchange">
                                    <option value="">-- Выберите этап --</option>
                                    @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                                    {
                                        <option value="@stage.Id">@stage.Name</option>
                                    }
                                </select>
                                @if (!selectedGroupStageId.HasValue)
                                {
                                    <div class="text-danger small mt-1">Необходимо выбрать этап для создания группы</div>
                                }
                            </div>

                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                Будет создана группа <strong>@(string.IsNullOrWhiteSpace(newGroupName) ? "Новая группа" : newGroupName)</strong>
                                @if (selectedGroupStageId.HasValue)
                                {
                                    var stage = stages.FirstOrDefault(s => s.Id == selectedGroupStageId);
                                    <span>в этапе <strong>@stage?.Name</strong></span>
                                }
                                и в нее будут перемещены <strong>@selectedItems.Count</strong> позиций.
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseGroupModal">Отмена</button>
                            <button class="btn btn-success" @onclick="CreateGroupAndMove" 
                                    disabled="@(isSaving || string.IsNullOrWhiteSpace(newGroupName) || !selectedGroupStageId.HasValue)">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Создать группу и переместить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно редактирования сметы -->
        @if (showEditModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">✏️ Редактирование сметы</h5>
                            <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Название сметы</label>
                                <input type="text" class="form-control" @bind="editName" placeholder="Введите название сметы" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Описание</label>
                                <textarea class="form-control" @bind="editDescription" rows="3" placeholder="Описание сметы"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Статус</label>
                                <select class="form-select" @bind="editStatus">
                                    <option value="Черновик">Черновик</option>
                                    <option value="В работе">В работе</option>
                                    <option value="Согласование">Согласование</option>
                                    <option value="Утверждена">Утверждена</option>
                                    <option value="Завершена">Завершена</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Менеджер</label>
                                <input type="text" class="form-control" @bind="editManagerName" placeholder="ФИО менеджера" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Email менеджера</label>
                                <input type="email" class="form-control" @bind="editManagerEmail" placeholder="email@example.com" />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseEditModal">Отмена</button>
                            <button class="btn btn-primary" @onclick="SaveEstimateChanges" disabled="@isSavingEdit">
                                @if (isSavingEdit)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Сохранить изменения
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно подтверждения удаления этапа -->
        @if (showDeleteStageModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">⚠️ Удаление этапа</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteStageModal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="fw-bold">Вы действительно хотите удалить этап <span class="text-danger">"@(stageToDelete?.Name)"</span>?</p>
                            
                            @if (stageItemsCount > 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Внимание!</strong> Вместе с этапом будут удалены:
                                    <ul class="mt-2 mb-0">
                                        <li><strong>@stageItemsCount</strong> позиций</li>
                                        @{
                                            var groupsCount = groups.Count(g => g.StageId == stageToDelete?.Id);
                                            if (groupsCount > 0)
                                            {
                                                <li><strong>@groupsCount</strong> групп</li>
                                            }
                                        }
                                    </ul>
                                    <p class="mt-2 mb-0 text-danger">Это действие нельзя отменить!</p>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">В этом этапе нет позиций.</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseDeleteStageModal">Отмена</button>
                            <button class="btn btn-danger" @onclick="ConfirmDeleteStage" disabled="@isSaving">
