@page "/estimate/{id:int}"
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@using Feniks.Shared.Models
@using SharedEstimate = Feniks.Shared.Models.Estimate
@using SharedConstructionObject = Feniks.Shared.Models.ConstructionObject
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject NotificationService NotificationService

<link href="css/estimate.css" rel="stylesheet" />

<div class="estimate-page" @onclick="CloseStatusDropdown">
    <!-- Хлебные крошки -->
    <div class="breadcrumbs mb-3">
        <a href="/">Главная</a> <span class="mx-2">›</span>
        <a href="/objects">Объекты</a> <span class="mx-2">›</span>
        <span>@(estimate?.Name ?? "")</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка сметы...</p>
        </div>
    }
    else if (estimate == null)
    {
        <div class="alert alert-danger">
            Смета не найдена
        </div>
    }
    else
    {
        <!-- Индикатор сохранения -->
        @if (isSaving)
        {
            <div class="position-fixed top-0 end-0 m-3 p-2 bg-success text-white rounded">
                <i class="bi bi-check-circle me-1"></i>Сохранено
            </div>
        }

        <!-- Заголовок сметы -->
        <div class="estimate-header bg-white rounded-3 shadow-sm p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <h1 class="h3 mb-0">@estimate.Name  @customerTotal.ToString("N0") ₽</h1>
                    </div>
                    <div class="d-flex gap-4 text-muted flex-wrap">
                        <span><i class="bi bi-building me-1"></i> Объект: @objectName</span>
                        <span><i class="bi bi-person me-1"></i> Менеджеры: @estimate.ManagerName, @estimate.ManagerEmail</span>
                    </div>
                    <div class="d-flex gap-3 mt-2 align-items-center">
                        <!-- Выпадающий список для выбора статуса -->
                        <div style="position: relative; display: inline-block;" @onclick:stopPropagation="true">
                            <button class="btn btn-sm p-0 border-0" @onclick="ToggleStatusDropdown" style="background: none;">
                                <span class="badge @GetStatusBadge(estimate.Status)" style="cursor: pointer; padding: 0.5em 0.8em;">
                                    @estimate.Status <i class="bi bi-chevron-down ms-1 small"></i>
                                </span>
                            </button>
                            
                            @if (showStatusDropdown)
                            {
                                <div style="position: absolute; top: 30px; left: 0; z-index: 1000; background: white; border: 1px solid rgba(0,0,0,0.15); border-radius: 4px; box-shadow: 0 6px 12px rgba(0,0,0,0.175); min-width: 160px; padding: 5px 0;">
                                    <button class="dropdown-item" @onclick="SetStatusDraft" style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none; @(estimate.Status == "Черновик" ? "background-color: #e7f1ff; color: #0d6efd;" : "")">
                                        <span class="badge bg-secondary me-2" style="font-size: 0.8em;">⬤</span> Черновик
                                    </button>
                                    <button class="dropdown-item" @onclick="SetStatusApproval" style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none; @(estimate.Status == "Согласование" ? "background-color: #e7f1ff; color: #0d6efd;" : "")">
                                        <span class="badge bg-info me-2" style="font-size: 0.8em;">⬤</span> Согласование
                                    </button>
                                    <button class="dropdown-item" @onclick="SetStatusInProgress" style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none; @(estimate.Status == "В работе" ? "background-color: #e7f1ff; color: #0d6efd;" : "")">
                                        <span class="badge bg-primary me-2" style="font-size: 0.8em;">⬤</span> В работе
                                    </button>
                                    <button class="dropdown-item" @onclick="SetStatusCompleted" style="display: block; width: 100%; padding: 8px 16px; text-align: left; background: none; border: none; @(estimate.Status == "Завершена" ? "background-color: #e7f1ff; color: #0d6efd;" : "")">
                                        <span class="badge bg-success me-2" style="font-size: 0.8em;">⬤</span> Завершена
                                    </button>
                                </div>
                            }
                        </div>                        
                        <!-- Кнопка для открытия модального окна редактирования -->
                        <button class="btn btn-link text-muted p-0 border-0" @onclick="OpenEditModal" style="text-decoration: none;">
                            <i class="bi bi-pencil me-1"></i>Режим правки
                        </button>
                        
                        <span class="text-muted"><i class="bi bi-lock me-1"></i>Фиксация цены заказчика</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary">Экспорт</button>
                    <button class="btn btn-sm btn-outline-secondary">Обновить цены</button>
                    <button class="btn btn-sm btn-outline-secondary">Создать копию</button>
                    <button class="btn btn-sm btn-outline-secondary">Архивировать</button>
                </div>
            </div>
        </div>

<!-- Общий сворачиваемый блок стоимости -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light py-2" @onclick="ToggleCostSection" style="cursor: pointer;">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <span class="btn-collapse">
                    <i class="bi @(expandedCostSection ? "bi-chevron-down" : "bi-chevron-right")"></i>
                </span>
            </div>
            <div class="row g-0 flex-grow-1 ms-2">
                <!-- Заголовок себестоимости -->
                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-center pe-3">
                        <h6 class="fw-bold fs-5 mb-0">Себестоимость: @totalCost.ToString("N0") ₽</h6>
                        <!--<span class="fw-bold fs-5 ms-2">@totalCost.ToString("N0") ₽</span>-->
                    </div>
                </div>
                <!-- Заголовок прибыли -->
                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-center pe-3">
                        <h6 class="fw-bold fs-5 mb-0" style="color: #b45f06;">Прибыль: @profitTotal.ToString("N0") ₽</h6>
                        <!--<span class="fw-bold fs-5 ms-2" style="color: #b45f06;">@profitTotal.ToString("N0") ₽</span>-->
                    </div>
                </div>
                <!-- Заголовок заказчика -->
                <div class="col-md-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h6 class="fw-bold fs-5 mb-0 text-success">Стоимость для заказчика: @customerTotal.ToString("N0") ₽</h6>
                        <!--<span class="fw-bold fs-5 ms-2 text-success">@customerTotal.ToString("N0") ₽</span>-->
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    @if (expandedCostSection)
    {
        <div class="card-body">
            <div class="row g-4">
                <!-- Детали себестоимости -->
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Работы</span>
                                <span class="fw-bold">@workCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Материалы</span>
                                <span class="fw-bold">@materialCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Механизмы</span>
                                <span class="fw-bold">@machineryCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Доставка</span>
                                <span class="fw-bold">@deliveryCost.ToString("N0") ₽</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Детали прибыли -->
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Работы</span>
                                <span class="fw-bold" style="color: #b45f06;">@profitWork.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Материалы</span>
                                <span class="fw-bold" style="color: #b45f06;">@profitMaterial.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Механизмы</span>
                                <span class="fw-bold" style="color: #b45f06;">@profitMachineryCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Доставка</span>
                                <span class="fw-bold" style="color: #b45f06;">@profitDelivery.ToString("N0") ₽</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Детали заказчика -->
                <div class="col-md-4">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Работы</span>
                                <span class="fw-bold text-success">@customerWorkCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Материалы</span>
                                <span class="fw-bold text-success">@customerMaterialCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Механизмы</span>
                                <span class="fw-bold text-success">@customerMachineryCost.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Доставка</span>
                                <span class="fw-bold text-success">@customerDeliveryCost.ToString("N0") ₽</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

        <!-- Этапы сметы -->
        <div class="stages-container">
            @if (!stages.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-layers fs-1 d-block mb-3"></i>
                    <p>Нет этапов в смете</p>
                    <button class="btn btn-outline-primary" @onclick="AddStage">
                        Добавить первый этап
                    </button>
                </div>
            }
            else
            {
                @foreach (var stage in stages.OrderBy(s => s.OrderIndex))
                {
                    <div class="stage-card card shadow-sm mb-4">
                        <div class="card-header bg-light py-2" @onclick="() => ToggleStage(stage.Id)">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2 flex-grow-1">
                                    <span class="btn-collapse">
                                        <i class="bi @(GetStageExpanded(stage.Id) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                    </span>
                                    <span class="badge bg-secondary me-1">@(stages.OrderBy(s => s.OrderIndex).ToList().IndexOf(stage) + 1)</span>
                                    
                                    @if (editingStageId == stage.Id)
                                    {
                                        <input type="text" class="form-control form-control-sm" @bind="editingStageName" 
                                               style="width: 300px;" @onkeydown="(e) => HandleStageEnter(e, stage)" 
                                               @onclick:stopPropagation="true" />
                                        <button class="btn btn-sm btn-success" @onclick="() => SaveStage(stage)" @onclick:stopPropagation="true">✓</button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditStage" @onclick:stopPropagation="true">✗</button>
                                    }
                                    else
                                    {
                                        <h6 class="mb-0 fw-bold">@stage.Name</h6>
                                        <button class="btn btn-sm btn-link py-0" @onclick="() => EditStage(stage)" @onclick:stopPropagation="true">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-link py-0 text-danger" @onclick="() => ShowDeleteStageModal(stage)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                                <div class="d-flex align-items-center gap-3" @onclick:stopPropagation="true">
                                    <span class="badge bg-light text-dark">💰 @GetStageTotal(stage.Id).ToString("N0") ₽</span>
                                    <span class="badge" style="background-color: #ffe0b5; color: #b45f06;">📈 @GetStageProfit(stage.Id).ToString("N0") ₽</span>
                                    <span class="badge bg-success text-white">📊 @GetStageCustomerTotal(stage.Id).ToString("N0") ₽</span>
                                </div>
                            </div>
                        </div>

                        @if (GetStageExpanded(stage.Id))
                        {
                            <div class="card-body p-3">
                                <!-- Панель инструментов для этапа -->
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <button class="btn btn-primary btn-sm" @onclick="() => ShowAddItemDialog(stage.Id)">
                                        <i class="bi bi-plus-circle me-1"></i>+ позиция
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-download me-1"></i>Импорт
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-percent me-1"></i>% Наценки
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm">
                                        <i class="bi bi-book me-1"></i>Справочники
                                    </button>
                                    <span class="ms-auto text-muted small">Доп. работы: + добавить</span>
                                </div>

                                @{
                                    var stageGroups = groups.Where(g => g.StageId == stage.Id).OrderBy(g => g.OrderIndex).ToList();
                                }

                                @foreach (var group in stageGroups)
                                {
                                    <div class="group-card card bg-light mb-3 border">
                                        <div class="card-header bg-secondary bg-opacity-10 py-1" @onclick="() => ToggleGroup(group.Id)">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="d-flex align-items-center gap-2 flex-grow-1">
                                                    <span class="btn-collapse">
                                                        <i class="bi @(GetGroupExpanded(group.Id) ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                                    </span>
                                                    @{
                                                        int stageIndex = stages.OrderBy(s => s.OrderIndex).ToList().IndexOf(stage) + 1;
                                                        int groupIndex = stageGroups.IndexOf(group) + 1;
                                                    }
                                                    <span class="badge bg-info me-1">@stageIndex.@groupIndex</span>
                                                    
                                                    @if (editingGroupId == group.Id)
                                                    {
                                                        <input type="text" class="form-control form-control-sm" @bind="editingGroupName" 
                                                               style="width: 250px;" @onkeydown="(e) => HandleGroupEnter(e, group)" 
                                                               @onclick:stopPropagation="true" />
                                                        <button class="btn btn-sm btn-success" @onclick="() => SaveGroup(group)" @onclick:stopPropagation="true">✓</button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="CancelEditGroup" @onclick:stopPropagation="true">✗</button>
                                                    }
                                                    else
                                                    {
                                                        <span class="fw-bold">@group.Name</span>
                                                        <button class="btn btn-sm btn-link py-0" @onclick="() => EditGroup(group)" @onclick:stopPropagation="true">✏️</button>
                                                    }
                                                </div>
                                                <div @onclick:stopPropagation="true">
                                                    @{
                                                        var groupTotal = items.Where(i => i.GroupId == group.Id).Sum(i => i.Price * i.Quantity);
                                                        var groupCustomerTotal = items.Where(i => i.GroupId == group.Id).Sum(i => i.CustomerPrice * i.Quantity);
                                                        var groupProfit = groupCustomerTotal - groupTotal;
                                                    }
                                                    <span class="badge bg-light text-dark me-1">💰 @groupTotal.ToString("N0") ₽</span>
                                                    <span class="badge me-1" style="background-color: #ffe0b5; color: #b45f06;">📈 @groupProfit.ToString("N0") ₽</span>
                                                    <span class="badge bg-success text-white">📊 @groupCustomerTotal.ToString("N0") ₽</span>
                                                </div>
                                            </div>
                                        </div>

                                        @if (GetGroupExpanded(group.Id))
                                        {
                                            <div class="card-body p-2">
                                                @{
                                                    var groupItems = items.Where(i => i.GroupId == group.Id).OrderBy(i => i.OrderIndex).ToList();
                                                }
                                                @if (groupItems.Any())
                                                {
                                                    <div class="table-responsive">
                                                        <table class="table table-sm table-hover align-middle mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th style="width: 30px"></th>
                                                                    <th style="width: 60px">№</th>
                                                                    <th style="width: 50px">Тип</th>
                                                                    <th>Наименование</th>
                                                                    <th style="width: 50px">Ед.</th>
                                                                    <th style="width: 70px">Кол-во</th>
                                                                    <th style="width: 80px">Цена</th>
                                                                    <th style="width: 90px">Сумма</th>
                                                                    <th style="width: 60px">Наценка %</th>
                                                                    <th style="width: 80px">Цена зак.</th>
                                                                    <th style="width: 90px">Сумма зак.</th>
                                                                    <th style="width: 40px"></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @for (int itemIndex = 0; itemIndex < groupItems.Count; itemIndex++)
                                                                {
                                                                    var item = groupItems[itemIndex];
                                                                    var total = item.Price * item.Quantity;
                                                                    var customerTotal = item.CustomerPrice * item.Quantity;
                                                                    <tr data-type="@item.Type" class="@(selectedItems.Contains(item.Id) ? "table-primary" : "")">
                                                                        <td><input type="checkbox" @onchange="() => ToggleItemSelection(item.Id)" checked="@selectedItems.Contains(item.Id)" /></td>
                                                                        <td>@stageIndex.@groupIndex.@(itemIndex + 1)</td>
                                                                        <td>
                                                                            <select class="form-select form-select-sm type-field" @bind="item.Type" @bind:event="oninput" @onblur="() => OnTypeChanged(item)">
                                                                                <option value="P">P</option>
                                                                                <option value="M">M</option>
                                                                                <option value="X">X</option>
                                                                                <option value="D">D</option>
                                                                            </select>
                                                                        </td>
                                                                        <td><input type="text" class="form-control form-control-sm" @bind="item.Name" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                                        <td><input type="text" class="form-control form-control-sm" @bind="item.Unit" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.Quantity" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.Price" @bind:event="oninput" @onblur="() => OnPriceChanged(item)" /></td>
                                                                        <td class="fw-bold">@total.ToString("N2") ₽</td>
                                                                        <td><input type="number" class="form-control form-control-sm markup-field" @bind="item.Markup" @bind:event="oninput" @onblur="() => OnMarkupChanged(item)" /></td>
                                                                        <td><input type="number" class="form-control form-control-sm" @bind="item.CustomerPrice" @bind:event="oninput" @onblur="() => OnCustomerPriceChanged(item)" /></td>
                                                                        <td class="fw-bold text-success">@customerTotal.ToString("N2") ₽</td>
                                                                        <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)"><i class="bi bi-trash"></i></button></td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <p class="text-muted small mb-0 py-2">Нет позиций в группе</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                }

                                <!-- Позиции без группы в этом этапе -->
                                @{
                                    var ungroupedItems = items.Where(i => i.GroupId == null && i.StageId == stage.Id).ToList();
                                }
                                @if (ungroupedItems.Any())
                                {
                                    <div class="mt-3">
                                        <h6 class="mb-2">Позиции без группы</h6>
                                        <div class="table-responsive">
                                            <table class="table table-sm table-hover align-middle">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 30px"></th>
                                                        <th style="width: 60px">№</th>
                                                        <th style="width: 50px">Тип</th>
                                                        <th>Наименование</th>
                                                        <th style="width: 50px">Ед.</th>
                                                        <th style="width: 70px">Кол-во</th>
                                                        <th style="width: 80px">Цена</th>
                                                        <th style="width: 90px">Стоимость</th>
                                                        <th style="width: 60px">Наценка %</th>
                                                        <th style="width: 80px">Цена зак.</th>
                                                        <th style="width: 90px">Стоимость зак.</th>
                                                        <th style="width: 40px"></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @for (int i = 0; i < ungroupedItems.Count; i++)
                                                    {
                                                        var item = ungroupedItems[i];
                                                        var total = item.Price * item.Quantity;
                                                        var customerTotal = item.CustomerPrice * item.Quantity;
                                                        <tr data-type="@item.Type" class="@(selectedItems.Contains(item.Id) ? "table-primary" : "")">
                                                            <td><input type="checkbox" @onchange="() => ToggleItemSelection(item.Id)" checked="@selectedItems.Contains(item.Id)" /></td>
                                                            <td>@(i + 1)</td>
                                                            <td>
                                                                <select class="form-select form-select-sm type-field" @bind="item.Type" @bind:event="oninput" @onblur="() => OnTypeChanged(item)">
                                                                    <option value="P">P</option>
                                                                    <option value="M">M</option>
                                                                    <option value="X">X</option>
                                                                    <option value="D">D</option>
                                                                </select>
                                                            </td>
                                                            <td><input type="text" class="form-control form-control-sm" @bind="item.Name" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="text" class="form-control form-control-sm" @bind="item.Unit" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.Quantity" @bind:event="oninput" @onblur="() => UpdateItem(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.Price" @bind:event="oninput" @onblur="() => OnPriceChanged(item)" /></td>
                                                            <td class="fw-bold">@total.ToString("N2") ₽</td>
                                                            <td><input type="number" class="form-control form-control-sm markup-field" @bind="item.Markup" @bind:event="oninput" @onblur="() => OnMarkupChanged(item)" /></td>
                                                            <td><input type="number" class="form-control form-control-sm" @bind="item.CustomerPrice" @bind:event="oninput" @onblur="() => OnCustomerPriceChanged(item)" /></td>
                                                            <td class="fw-bold text-success">@customerTotal.ToString("N2") ₽</td>
                                                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)"><i class="bi bi-trash"></i></button></td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                
                <!-- Кнопка добавления нового этапа -->
                <div class="text-center mt-4">
                    <button class="btn btn-outline-primary btn-lg" @onclick="AddStage">
                        <i class="bi bi-plus-circle me-2"></i>Добавить этап
                    </button>
                </div>
            }
        </div>

        <!-- Нижний колонтитул с выбранными позициями -->
        @if (selectedItems.Any())
        {
            <div class="card shadow-sm mt-4 position-sticky-bottom">
                <div class="card-body bg-light">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div>
                            <span class="fw-bold me-3">Выбрано позиций: @selectedItems.Count</span>
                            <span class="me-3">💰 Себестоимость: @selectedSum.ToString("N0") ₽</span>
                            <span class="me-3">📈 Прибыль: @selectedProfit.ToString("N0") ₽</span>
                            <span class="text-success">📊 Для заказчика: @selectedCustomerSum.ToString("N0") ₽</span>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-outline-primary" @onclick="CopySelected">
                                <i class="bi bi-files me-1"></i>Копировать
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ShowMoveToGroup">
                                <i class="bi bi-folder-plus me-1"></i>В группу
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">
                                <i class="bi bi-trash me-1"></i>Удалить
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Диалог добавления позиции -->
        @if (showAddDialog)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">➕ Добавить позицию</h5>
                            <button type="button" class="btn-close" @onclick="CloseAddDialog"></button>
                        </div>
                        <div class="modal-body">
                            <div class="row">
                                <div class="col-md-8 mb-3">
                                    <label class="form-label">Наименование *</label>
                                    <input type="text" class="form-control" @bind="newItem.Name" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Тип</label>
                                    <select class="form-select" @bind="newItem.Type">
                                        <option value="P">P - Работы</option>
                                        <option value="M">M - Материалы</option>
                                        <option value="X">X - Механизмы</option>
                                        <option value="D">D - Доставка</option>
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Ед. изм.</label>
                                    <input type="text" class="form-control" @bind="newItem.Unit" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Количество</label>
                                    <input type="number" class="form-control" @bind="newItem.Quantity" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Цена</label>
                                    <input type="number" class="form-control" @bind="newItem.Price" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Наценка, %</label>
                                    <input type="number" class="form-control" @bind="newItem.Markup" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Этап</label>
                                    <select class="form-select" @bind="newItem.StageId">
                                        <option value="">Выберите этап</option>
                                        @foreach (var stage in stages)
                                        {
                                            <option value="@stage.Id">@stage.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Группа (необязательно)</label>
                                    <select class="form-select" @bind="newItem.GroupId">
                                        <option value="">Без группы</option>
                                        @foreach (var group in groups.Where(g => g.StageId == newItem.StageId))
                                        {
                                            <option value="@group.Id">@group.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseAddDialog">Отмена</button>
                            <button class="btn btn-primary" @onclick="AddItem">Добавить</button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно для перемещения с возможностью создания новой группы -->
        @if (showMoveModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Переместить выбранные позиции (@selectedItems.Count шт.)</h5>
                            <button type="button" class="btn-close" @onclick="CloseMoveModal"></button>
                        </div>
                        <div class="modal-body">
                            @if (isCreatingNewGroup)
                            {
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Название новой группы</label>
                                    <input type="text" class="form-control" @bind="newGroupName" placeholder="Введите название группы" />
                                </div>
                                <div class="d-flex justify-content-end gap-2">
                                    <button class="btn btn-secondary" @onclick="CancelNewGroup">Отмена</button>
                                    <button class="btn btn-primary" @onclick="CreateNewGroupAndMove">Создать и переместить</button>
                                </div>
                            }
                            else
                            {
                                <select class="form-select" @bind="moveToGroupId">
                                    <option value="">-- Выберите группу --</option>
                                    <option value="-1" style="color: #0d6efd; font-weight: 500;">➕ Новая группа...</option>
                                    <option disabled>──────────</option>
                                    @foreach (var group in groups.OrderBy(g => g.StageId).ThenBy(g => g.Name))
                                    {
                                        var stageName = stages.FirstOrDefault(s => s.Id == group.StageId)?.Name ?? "Без этапа";
                                        <option value="@group.Id">@group.Name (@stageName)</option>
                                    }
                                </select>
                            }
                        </div>
                        <div class="modal-footer">
                            @if (!isCreatingNewGroup)
                            {
                                <button class="btn btn-secondary" @onclick="CloseMoveModal">Отмена</button>
                                <button class="btn btn-primary" @onclick="MoveToGroup">Переместить</button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно редактирования сметы -->
        @if (showEditModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">✏️ Редактирование сметы</h5>
                            <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Название сметы</label>
                                <input type="text" class="form-control" @bind="editName" placeholder="Введите название сметы" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Описание</label>
                                <textarea class="form-control" @bind="editDescription" rows="3" placeholder="Описание сметы"></textarea>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Статус</label>
                                <select class="form-select" @bind="editStatus">
                                    <option value="Черновик">Черновик</option>
                                    <option value="В работе">В работе</option>
                                    <option value="Согласование">Согласование</option>
                                    <option value="Утверждена">Утверждена</option>
                                    <option value="Завершена">Завершена</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Менеджер</label>
                                <input type="text" class="form-control" @bind="editManagerName" placeholder="ФИО менеджера" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Email менеджера</label>
                                <input type="email" class="form-control" @bind="editManagerEmail" placeholder="email@example.com" />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseEditModal">Отмена</button>
                            <button class="btn btn-primary" @onclick="SaveEstimateChanges" disabled="@isSavingEdit">
                                @if (isSavingEdit)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Сохранить изменения
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Модальное окно подтверждения удаления этапа -->
        @if (showDeleteStageModal)
        {
            <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">⚠️ Удаление этапа</h5>
                            <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteStageModal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="fw-bold">Вы действительно хотите удалить этап <span class="text-danger">"@(stageToDelete?.Name)"</span>?</p>
                            
                            @if (stageItemsCount > 0)
                            {
                                <div class="alert alert-warning">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <strong>Внимание!</strong> Вместе с этапом будут удалены:
                                    <ul class="mt-2 mb-0">
                                        <li><strong>@stageItemsCount</strong> позиций</li>
                                        @{
                                            var groupsCount = groups.Count(g => g.StageId == stageToDelete?.Id);
                                            if (groupsCount > 0)
                                            {
                                                <li><strong>@groupsCount</strong> групп</li>
                                            }
                                        }
                                    </ul>
                                    <p class="mt-2 mb-0 text-danger">Это действие нельзя отменить!</p>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">В этом этапе нет позиций.</p>
                            }
                        </div>
                        <div class="modal-footer">
                            <button class="btn btn-secondary" @onclick="CloseDeleteStageModal">Отмена</button>
                            <button class="btn btn-danger" @onclick="ConfirmDeleteStage" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Удалить этап
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private SharedEstimate? estimate;
    private string objectName = "";
    private bool isLoading = true;
    private bool isSaving = false;
    private List<EstimateStage> stages = new();
    private List<EstimateItemGroup> groups = new();
    private List<EstimateItem> items = new();
    private HashSet<int> selectedItems = new();

    private int? editingStageId;
    private string editingStageName = "";
    private int? editingGroupId;
    private string editingGroupName = "";
    private bool showAddDialog = false;
    private NewItem newItem = new();
    private bool showMoveModal = false;
    private int? moveToGroupId;

    // Поле для общего сворачивания блока стоимости
    private bool expandedCostSection = true;

    private void ToggleCostSection()
    {
        expandedCostSection = !expandedCostSection;
        StateHasChanged();
    }
    
    // Поля для создания группы
    private bool isCreatingNewGroup = false;
    private string newGroupName = "";
    private int? selectedStageIdForNewGroup;

    // Поля для модального окна редактирования сметы
    private bool showEditModal = false;
    private bool isSavingEdit = false;
    private string editName = "";
    private string editDescription = "";
    private string editStatus = "";
    private string editManagerName = "";
    private string editManagerEmail = "";

    // Поля для удаления этапа
    private bool showDeleteStageModal = false;
    private EstimateStage? stageToDelete;
    private int stageItemsCount = 0;

    // Словари для хранения состояния свертывания
    private Dictionary<int, bool> stageExpandedState = new();
    private Dictionary<int, bool> groupExpandedState = new();

    // Поле для статусного dropdown
    private bool showStatusDropdown = false;

    private class NewItem
    {
        public string Name { get; set; } = "";
        public string Unit { get; set; } = "шт";
        public decimal Quantity { get; set; } = 1;
        public decimal Price { get; set; } = 0;
        public decimal Markup { get; set; } = 0;
        public string Type { get; set; } = "P";
        public int? StageId { get; set; }
        public int? GroupId { get; set; }
    }

    private async Task SetStatusDraft() => await ChangeStatus("Черновик");
    private async Task SetStatusApproval() => await ChangeStatus("Согласование");
    private async Task SetStatusInProgress() => await ChangeStatus("В работе");
    private async Task SetStatusCompleted() => await ChangeStatus("Завершена");

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine($"🚀 Estimate инициализирован с ID: {Id}");
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        Console.WriteLine($"🔄 Параметр ID изменился на: {Id}");
        _ = LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            Console.WriteLine($"📥 Загрузка данных для сметы ID: {Id}");
            
            stages.Clear();
            groups.Clear();
            items.Clear();
            stageExpandedState.Clear();
            groupExpandedState.Clear();

            estimate = await Http.GetFromJsonAsync<SharedEstimate>($"http://localhost:5050/api/Estimates/{Id}");

            if (estimate != null)
            {
                var obj = await Http.GetFromJsonAsync<SharedConstructionObject>($"http://localhost:5050/api/ConstructionObjects/{estimate.ConstructionObjectId}");
                objectName = obj?.Name ?? "Неизвестно";

                stages = await Http.GetFromJsonAsync<List<EstimateStage>>($"http://localhost:5050/api/EstimateStages/by-estimate/{Id}") ?? new();

                foreach (var stage in stages)
                {
                    stageExpandedState[stage.Id] = stage.IsExpanded;
                }

                groups = await Http.GetFromJsonAsync<List<EstimateItemGroup>>($"http://localhost:5050/api/EstimateItemGroups/by-estimate/{Id}") ?? new();

                foreach (var group in groups)
                {
                    groupExpandedState[group.Id] = group.IsExpanded;
                }

                items = await Http.GetFromJsonAsync<List<EstimateItem>>($"http://localhost:5050/api/EstimateItems/by-estimate/{Id}") ?? new();

                Console.WriteLine($"=== ЗАГРУЖЕНО ПОЗИЦИЙ: {items.Count} для сметы {Id} ===");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Console.WriteLine($"🗑️ Estimate компонент освобожден для ID: {Id}");
    }

    private bool GetStageExpanded(int stageId) => stageExpandedState.ContainsKey(stageId) ? stageExpandedState[stageId] : true;
    private bool GetGroupExpanded(int groupId) => groupExpandedState.ContainsKey(groupId) ? groupExpandedState[groupId] : true;

    private void ToggleStage(int stageId)
    {
        if (stageExpandedState.ContainsKey(stageId))
            stageExpandedState[stageId] = !stageExpandedState[stageId];
        else
            stageExpandedState[stageId] = false;
        StateHasChanged();
    }

    private void ToggleGroup(int groupId)
    {
        if (groupExpandedState.ContainsKey(groupId))
            groupExpandedState[groupId] = !groupExpandedState[groupId];
        else
            groupExpandedState[groupId] = false;
        StateHasChanged();
    }

    private async Task UpdateItem(EstimateItem item)
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var update = new
            {
                item.Id,
                item.Name,
                item.Unit,
                item.Quantity,
                item.Price,
                item.Markup,
                item.Type,
                CustomerPrice = item.CustomerPrice
            };

            await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateItems/{item.Id}", update);
            isSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка обновления: {ex.Message}");
            isSaving = false;
        }
    }

    private void OnMarkupChanged(EstimateItem item)
    {
        item.CustomerPrice = item.Price * (1 + item.Markup / 100);
        _ = UpdateItem(item);
    }

    private void OnCustomerPriceChanged(EstimateItem item)
    {
        if (item.Price > 0)
            item.Markup = ((item.CustomerPrice - item.Price) / item.Price) * 100;
        _ = UpdateItem(item);
    }

    private void OnPriceChanged(EstimateItem item)
    {
        item.CustomerPrice = item.Price * (1 + item.Markup / 100);
        _ = UpdateItem(item);
    }

    private async Task OnTypeChanged(EstimateItem item)
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var update = new
            {
                item.Id,
                item.Name,
                item.Unit,
                item.Quantity,
                item.Price,
                item.Markup,
                item.Type,
                CustomerPrice = item.CustomerPrice
            };

            await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateItems/{item.Id}", update);
            isSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка: {ex.Message}");
            isSaving = false;
        }
    }

    private async Task AddStage()
    {
        try
        {
            isSaving = true;
            
            int nextOrderIndex = stages.Count;
            
            var newStage = new 
            { 
                EstimateId = Id, 
                Name = $"Этап {stages.Count + 1}", 
                Description = "",
                OrderIndex = nextOrderIndex, 
                IsExpanded = true 
            };
            
            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateStages", newStage);
            
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<EstimateStage>();
                if (created != null)
                {
                    stages.Add(created);
                    stageExpandedState[created.Id] = true;
                    NotificationService.NotifyDataChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void ShowAddItemDialog(int? stageId)
    {
        newItem = new NewItem { StageId = stageId };
        showAddDialog = true;
        StateHasChanged();
    }

    private void CloseAddDialog()
    {
        showAddDialog = false;
        newItem = new NewItem();
        StateHasChanged();
    }

    private async Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Name) || newItem.StageId == null)
        {
            await JS.InvokeVoidAsync("alert", "Заполните название и выберите этап");
            return;
        }

        var itemToAdd = new
        {
            EstimateId = Id,
            GroupId = newItem.GroupId,
            StageId = newItem.StageId,
            Name = newItem.Name,
            Unit = newItem.Unit,
            Quantity = newItem.Quantity,
            Price = newItem.Price,
            Markup = newItem.Markup,
            Type = newItem.Type,
            OrderIndex = items.Count,
            CustomerPrice = newItem.Price * (1 + newItem.Markup / 100)
        };

        var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", itemToAdd);
        if (response.IsSuccessStatusCode)
        {
            var createdItem = await response.Content.ReadFromJsonAsync<EstimateItem>();
            if (createdItem != null)
            {
                items.Add(createdItem);
                StateHasChanged();
            }
            CloseAddDialog();
            NotificationService.NotifyDataChanged();
        }
    }

    private void ToggleItemSelection(int itemId)
    {
        if (selectedItems.Contains(itemId))
            selectedItems.Remove(itemId);
        else
            selectedItems.Add(itemId);
        StateHasChanged();
    }

    private async Task DeleteItem(int itemId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Удалить позицию?"))
        {
            await Http.DeleteAsync($"http://localhost:5050/api/EstimateItems/{itemId}");
            await LoadData();
            selectedItems.Remove(itemId);
            StateHasChanged();
        }
    }

    private async Task DeleteSelected()
    {
        if (selectedItems.Count == 0) return;
        if (await JS.InvokeAsync<bool>("confirm", $"Удалить {selectedItems.Count} позиций?"))
        {
            foreach (var id in selectedItems.ToList())
                await Http.DeleteAsync($"http://localhost:5050/api/EstimateItems/{id}");
            
            await LoadData();
            selectedItems.Clear();
            StateHasChanged();
        }
    }

    private void EditStage(EstimateStage stage)
    {
        editingStageId = stage.Id;
        editingStageName = stage.Name;
        StateHasChanged();
    }

    private async Task SaveStage(EstimateStage stage)
    {
        if (!string.IsNullOrWhiteSpace(editingStageName))
        {
            try
            {
                isSaving = true;
                StateHasChanged();

                var update = new
                {
                    id = stage.Id,
                    name = editingStageName,
                    orderIndex = stage.OrderIndex,
                    isExpanded = stage.IsExpanded,
                    estimateId = stage.EstimateId
                };

                var response = await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateStages/{stage.Id}", update);

                if (response.IsSuccessStatusCode)
                {
                    stage.Name = editingStageName;
                    NotificationService.NotifyDataChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Ошибка: {ex.Message}");
            }
            finally
            {
                isSaving = false;
                CancelEditStage();
                StateHasChanged();
            }
        }
        else
        {
            CancelEditStage();
        }
    }

    private void CancelEditStage()
    {
        editingStageId = null;
        editingStageName = "";
        StateHasChanged();
    }

    private async Task HandleStageEnter(KeyboardEventArgs e, EstimateStage stage)
    {
        if (e.Key == "Enter")
            await SaveStage(stage);
    }

