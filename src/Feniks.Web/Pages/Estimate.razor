    private async Task ShowGroupModal()
    {
        if (selectedItems.Count == 0)
        {
            await JS.InvokeVoidAsync("alert", "Выберите позиции для группирования");
            return;
        }

        var selectedItemsList = items.Where(i => selectedItems.Contains(i.Id)).ToList();
        var distinctStages = selectedItemsList.Select(i => i.StageId).Distinct().ToList();
        
        if (distinctStages.Count == 1 && distinctStages.First().HasValue)
        {
            selectedGroupStageId = distinctStages.First().Value;
            Console.WriteLine($"✅ Все позиции из этапа {selectedGroupStageId}, предвыбираем его");
        }
        else
        {
            selectedGroupStageId = null;
            if (distinctStages.Count > 1)
            {
                Console.WriteLine($"⚠️ Позиции из разных этапов ({string.Join(", ", distinctStages)}), требуется выбор этапа");
            }
        }

        var itemsWithoutStage = selectedItemsList.Where(i => !i.StageId.HasValue || i.StageId == 0).ToList();
        
        if (itemsWithoutStage.Any())
        {
            var message = itemsWithoutStage.Count == 1
                ? "Выбранная позиция не привязана к этапу. После создания группы она будет автоматически привязана к выбранному этапу. Продолжить?"
                : $"Выбрано {itemsWithoutStage.Count} позиций без этапа. После создания группы они будут автоматически привязаны к выбранному этапу. Продолжить?";
            
            var confirmed = await JS.InvokeAsync<bool>("confirm", message);
            if (!confirmed)
            {
                return;
            }
        }

        var itemsInGroups = selectedItemsList.Where(i => i.GroupId.HasValue).ToList();
        
        if (itemsInGroups.Any())
        {
            var message = itemsInGroups.Count == 1 
                ? "Выбранная позиция уже находится в группе. При создании новой группы она будет перемещена в новую группу. Продолжить?"
                : $"Выбранные позиции ({itemsInGroups.Count} шт.) уже находятся в группах. При создании новой группы они будут перемещены в новую группу. Продолжить?";
            
            var confirmed = await JS.InvokeAsync<bool>("confirm", message);
            if (!confirmed)
            {
                return;
            }
        }
        
        newGroupName = $"Группа {DateTime.Now:dd.MM.yy HH:mm}";
        showGroupModal = true;
        StateHasChanged();
        
        Console.WriteLine($"=== ShowGroupModal ===");
        Console.WriteLine($"selectedGroupStageId: {selectedGroupStageId}");
        Console.WriteLine($"stages.Count: {stages.Count}");
    }

    private async Task CreateGroupAndMove()
    {
        Console.WriteLine($"=== CreateGroupAndMove ===");
        Console.WriteLine($"newGroupName: '{newGroupName}'");
        Console.WriteLine($"selectedGroupStageId: {selectedGroupStageId}");
        Console.WriteLine($"selectedItems count: {selectedItems.Count}");

        if (string.IsNullOrWhiteSpace(newGroupName))
        {
            await JS.InvokeVoidAsync("alert", "Введите название группы");
            return;
        }

        if (!selectedGroupStageId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Выберите этап для создания группы");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            int targetStageId = selectedGroupStageId.Value;

            var newGroup = new
            {
                stageId = targetStageId,
                name = newGroupName,
                orderIndex = groups.Count(g => g.StageId == targetStageId),
                isExpanded = true
            };

            Console.WriteLine($"Создание группы: {System.Text.Json.JsonSerializer.Serialize(newGroup)}");

            var groupResponse = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItemGroups", newGroup);
            
            if (groupResponse.IsSuccessStatusCode)
            {
                var createdGroup = await groupResponse.Content.ReadFromJsonAsync<EstimateItemGroup>();
                if (createdGroup != null)
                {
                    Console.WriteLine($"✅ Группа создана с ID: {createdGroup.Id}");
                    
                    groups.Add(createdGroup);
                    
                    var itemsToProcess = items.Where(i => selectedItems.Contains(i.Id)).ToList();
                    Console.WriteLine($"Перемещаем {itemsToProcess.Count} позиций");
                    
                    int successCount = 0;
                    
                    foreach (var item in itemsToProcess)
                    {
                        try
                        {
                            var updateItem = new
                            {
                                id = item.Id,
                                name = item.Name,
                                unit = item.Unit,
                                quantity = item.Quantity,
                                price = item.Price,
                                markup = item.Markup,
                                type = item.Type,
                                customerPrice = item.CustomerPrice,
                                stageId = targetStageId,
                                groupId = createdGroup.Id,
                                estimateId = item.EstimateId
                            };
                            
                            Console.WriteLine($"Обновление позиции {item.Id}: {System.Text.Json.JsonSerializer.Serialize(updateItem)}");
                            
                            var updateResponse = await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateItems/{item.Id}", updateItem);
                            
                            if (updateResponse.IsSuccessStatusCode)
                            {
                                Console.WriteLine($"✅ Позиция {item.Id} обновлена");
                                successCount++;
                            }
                            else
                            {
                                var errorContent = await updateResponse.Content.ReadAsStringAsync();
                                Console.WriteLine($"❌ Ошибка обновления позиции {item.Id}: {updateResponse.StatusCode} - {errorContent}");
                            }
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"❌ Исключение при обновлении позиции {item.Id}: {ex.Message}");
                        }
                    }

                    Console.WriteLine("Перезагрузка данных...");
                    await LoadData();
                    
                    selectedItems.Clear();
                    CloseGroupModal();
                    await NotifyChanges();
                    
                    if (successCount > 0)
                    {
                        await JS.InvokeVoidAsync("alert", $"✅ Группа '{newGroupName}' создана, {successCount} позиций перемещено");
                    }
                    else
                    {
                        await JS.InvokeVoidAsync("alert", $"⚠️ Группа создана, но позиции не перемещены. Проверьте консоль для деталей.");
                    }
                }
            }
            else
            {
                var error = await groupResponse.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка создания группы: {groupResponse.StatusCode} - {error}");
                await JS.InvokeVoidAsync("alert", $"Ошибка при создании группы: {groupResponse.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

