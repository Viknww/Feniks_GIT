            var selectedItemsList = items.Where(i => selectedItems.Contains(i.Id)).ToList();
            var distinctStages = selectedItemsList.Select(i => i.StageId).Distinct().ToList();
            
            if (distinctStages.Count == 1 && distinctStages.First().HasValue)
            {
                currentStageId = distinctStages.First().Value;
                Console.WriteLine($"✅ Все позиции из этапа {currentStageId}");
                
                var distinctGroups = selectedItemsList.Select(i => i.GroupId).Distinct().ToList();
                if (distinctGroups.Count == 1 && distinctGroups.First().HasValue)
                {
                    currentGroupId = distinctGroups.First().Value;
                    Console.WriteLine($"✅ Все позиции из группы {currentGroupId}");
                }
            }
            else
            {
                Console.WriteLine($"⚠️ Позиции из разных этапов: {string.Join(", ", distinctStages)}");
            }
        }

        if (target == "same" && mode == "copy")
        {
            _ = ExecuteCopyMoveSame();
            return;
        }

        string action = mode == "copy" ? "Копирование" : "Перемещение";
        string targetText = target switch
        {
            "group" => "в группу",
            "stage" => "в этап",
            _ => ""
        };
        copyMoveTitle = $"{action} позиций ({selectedItems.Count} шт.) {targetText}";

        if (target == "stage" && currentStageId.HasValue)
        {
            selectedTargetStageId = currentStageId.Value;
            Console.WriteLine($"🎯 Предустановлен этап {selectedTargetStageId} для {action}");
        }
        else if (target == "group" && currentGroupId.HasValue)
        {
            selectedTargetGroupId = currentGroupId.Value;
            var group = groups.FirstOrDefault(g => g.Id == currentGroupId.Value);
            if (group != null)
            {
                selectedGroupStageId = group.StageId;
                Console.WriteLine($"🎯 Предустановлена группа {selectedTargetGroupId} в этапе {selectedGroupStageId} для {action}");
            }
        }
        else
        {
            selectedTargetStageId = null;
            selectedTargetGroupId = null;
            selectedGroupStageId = null;
        }

        isCreatingNewGroup = false;
        newGroupName = "";
        showCopyMoveModal = true;
        
        Console.WriteLine($"ShowCopyMoveModal: Модальное окно открыто, currentStageId={currentStageId}, currentGroupId={currentGroupId}");
        StateHasChanged();
    }

    private async Task ExecuteCopyMoveSame()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var itemsToProcess = items.Where(i => selectedItems.Contains(i.Id)).ToList();

            foreach (var item in itemsToProcess)
            {
                var newItem = new
                {
                    EstimateId = Id,
                    GroupId = item.GroupId,
                    StageId = item.StageId,
                    Name = $"{item.Name} (копия)",
                    Unit = item.Unit,
                    Quantity = item.Quantity,
                    Price = item.Price,
                    Markup = item.Markup,
                    Type = item.Type,
                    OrderIndex = items.Count,
                    CustomerPrice = item.CustomerPrice
                };
                await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", newItem);
            }

            await LoadData();
            selectedItems.Clear();
            await NotifyChanges();
            
            await JS.InvokeVoidAsync("alert", $"✅ {itemsToProcess.Count} позиций скопировано");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при копировании: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

