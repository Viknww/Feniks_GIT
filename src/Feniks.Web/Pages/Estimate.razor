            return;

        try
        {
            isSaving = true;
            StateHasChanged();

            var update = new
            {
                Id = estimate.Id,
                Name = estimate.Name,
                Description = estimate.Description,
                Status = newStatus,
                ManagerName = estimate.ManagerName,
                ManagerEmail = estimate.ManagerEmail,
                ConstructionObjectId = estimate.ConstructionObjectId,
                TotalCost = estimate.TotalCost,
                CustomerPrice = estimate.CustomerPrice
            };

            var response = await Http.PutAsJsonAsync($"http://localhost:5050/api/Estimates/{estimate.Id}", update);

            if (response.IsSuccessStatusCode)
            {
                estimate.Status = newStatus;
                await NotifyChanges();
                StateHasChanged();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка изменения статуса: {error}");
            }
        }
        catch (Exception ex)
