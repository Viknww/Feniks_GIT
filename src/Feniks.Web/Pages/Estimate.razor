    private async Task CreateNewGroupAndContinue()
    {
        if (string.IsNullOrWhiteSpace(newGroupName))
        {
            await JS.InvokeVoidAsync("alert", "Введите название группы");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            int targetStageId;
            
            if (copyMoveTarget == "stage" && selectedTargetStageId.HasValue)
            {
                targetStageId = selectedTargetStageId.Value;
                Console.WriteLine($"Создание группы в выбранном этапе: {targetStageId}");
            }
            else if (currentStageId.HasValue)
            {
                targetStageId = currentStageId.Value;
                Console.WriteLine($"Создание группы в текущем этапе: {targetStageId}");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Не удалось определить этап для создания группы");
                isSaving = false;
                StateHasChanged();
                return;
            }

            Console.WriteLine($"Создание группы в диалоге копирования: stageId={targetStageId}, name={newGroupName}");

            var newGroup = new
            {
                stageId = targetStageId,
                name = newGroupName,
                orderIndex = groups.Count(g => g.StageId == targetStageId),
                isExpanded = true
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItemGroups", newGroup);
            
            if (response.IsSuccessStatusCode)
            {
                var createdGroup = await response.Content.ReadFromJsonAsync<EstimateItemGroup>();
                if (createdGroup != null)
                {
                    groups.Add(createdGroup);
                    selectedTargetGroupId = createdGroup.Id;
                    isCreatingNewGroup = false;
                    newGroupName = "";
                    
                    await JS.InvokeVoidAsync("alert", $"✅ Группа '{createdGroup.Name}' создана");
                    StateHasChanged();
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка при создании группы: {error}");
                await JS.InvokeVoidAsync("alert", $"❌ Ошибка при создании группы: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка создания группы: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task ExecuteCopyMove()
    {
        try
        {
            isSaving = true;
            StateHasChanged();

            var itemsToProcess = items.Where(i => selectedItems.Contains(i.Id)).ToList();
            var isCopy = copyMoveMode == "copy";

            if (isCreatingNewGroup)
            {
                await JS.InvokeVoidAsync("alert", "Сначала создайте группу");
                isSaving = false;
                StateHasChanged();
                return;
            }

            int processedCount = 0;
            
            foreach (var item in itemsToProcess)
            {
                int targetStageId;
                int? targetGroupId = selectedTargetGroupId;

                if (copyMoveTarget == "stage" && selectedTargetStageId.HasValue)
                {
                    targetStageId = selectedTargetStageId.Value;
                    Console.WriteLine($"Копирование в этап: {targetStageId}");
                }
                else if (copyMoveTarget == "group" && currentStageId.HasValue)
                {
                    targetStageId = currentStageId.Value;
                    Console.WriteLine($"Копирование в текущий этап: {targetStageId}");
                }
                else
                {
                    targetStageId = item.StageId ?? 0;
                    Console.WriteLine($"Копирование в исходный этап: {targetStageId}");
                }

                if (isCopy)
                {
                    var newItem = new
                    {
                        EstimateId = Id,
                        GroupId = targetGroupId,
                        StageId = targetStageId,
                        Name = $"{item.Name} (копия)",
                        Unit = item.Unit,
                        Quantity = item.Quantity,
                        Price = item.Price,
                        Markup = item.Markup,
                        Type = item.Type,
                        OrderIndex = items.Count + processedCount,
                        CustomerPrice = item.CustomerPrice
                    };

                    Console.WriteLine($"Копирование позиции: {System.Text.Json.JsonSerializer.Serialize(newItem)}");

                    var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", newItem);
                    
                    if (response.IsSuccessStatusCode)
                    {
                        processedCount++;
                    }
                    else
                    {
                        var error = await response.Content.ReadAsStringAsync();
                        Console.WriteLine($"Ошибка копирования позиции {item.Id}: {error}");
                    }
                }
                else
                {
                    var updateItem = new
                    {
                        item.Id,
                        item.Name,
                        item.Unit,
                        item.Quantity,
                        item.Price,
                        item.Markup,
                        item.Type,
                        CustomerPrice = item.CustomerPrice,
                        StageId = targetStageId,
                        GroupId = targetGroupId
                    };

                    Console.WriteLine($"Перемещение позиции {item.Id} в stage={targetStageId}, group={targetGroupId}");

                    var response = await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateItems/{item.Id}", updateItem);
                    
                    if (response.IsSuccessStatusCode)
                    {
                        processedCount++;
                    }
                    else
                    {
                        var error = await response.Content.ReadAsStringAsync();
                        Console.WriteLine($"Ошибка перемещения позиции {item.Id}: {error}");
                    }
                }
            }

            await LoadData();
            selectedItems.Clear();
            CloseCopyMoveModal();
            await NotifyChanges();
            
            if (processedCount > 0)
            {
                await JS.InvokeVoidAsync("alert", 
                    isCopy 
                        ? $"✅ {processedCount} из {itemsToProcess.Count} позиций скопировано" 
                        : $"✅ {processedCount} из {itemsToProcess.Count} позиций перемещено");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "❌ Ни одна позиция не была обработана");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при {copyMoveMode}: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

