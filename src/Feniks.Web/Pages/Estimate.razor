        if (estimate == null || estimate.Status == newStatus)
            return;

        try
        {
            isSaving = true;
            StateHasChanged();

            var update = new
            {
                Id = estimate.Id,
                Name = estimate.Name,
                Description = estimate.Description,
                Status = newStatus,
                ManagerName = estimate.ManagerName,
                ManagerEmail = estimate.ManagerEmail,
                ConstructionObjectId = estimate.ConstructionObjectId,
                TotalCost = estimate.TotalCost,
                CustomerPrice = estimate.CustomerPrice
            };

