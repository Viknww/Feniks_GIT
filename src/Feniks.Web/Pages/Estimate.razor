    // НОВЫЙ МЕТОД: удаление группы
    private async Task DeleteGroup(int groupId)
    {
        var group = groups.FirstOrDefault(g => g.Id == groupId);
        if (group == null) return;

        var itemsInGroup = items.Where(i => i.GroupId == groupId).ToList();
        
        var message = itemsInGroup.Any()
            ? $"В группе '{group.Name}' есть {itemsInGroup.Count} позиций. Они будут перемещены в 'Позиции без группы'. Продолжить?"
            : $"Удалить группу '{group.Name}'?";

        if (await JS.InvokeAsync<bool>("confirm", message))
        {
            try
            {
                isSaving = true;
                StateHasChanged();

                foreach (var item in itemsInGroup)
                {
                    var updateItem = new
                    {
                        item.Id,
                        item.Name,
                        item.Unit,
                        item.Quantity,
                        item.Price,
                        item.Markup,
                        item.Type,
                        CustomerPrice = item.CustomerPrice,
                        StageId = item.StageId,
                        GroupId = (int?)null
                    };

                    await Http.PutAsJsonAsync($"http://localhost:5050/api/EstimateItems/{item.Id}", updateItem);
                }

                var response = await Http.DeleteAsync($"http://localhost:5050/api/EstimateItemGroups/{groupId}");
                
                if (response.IsSuccessStatusCode)
                {
                    Console.WriteLine($"✅ Группа {groupId} удалена");
                    
                    await LoadData();
                    
                    selectedItems.RemoveWhere(id => itemsInGroup.Any(i => i.Id == id));
                    
                    await NotifyChanges();
                    
                    await JS.InvokeVoidAsync("alert", $"✅ Группа '{group.Name}' удалена, {itemsInGroup.Count} позиций перемещено в 'Позиции без группы'");
                }
                else
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"❌ Ошибка удаления группы: {error}");
                    await JS.InvokeVoidAsync("alert", $"Ошибка при удалении группы: {response.StatusCode}");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"❌ Ошибка: {ex.Message}");
                await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
            finally
            {
                isSaving = false;
                StateHasChanged();
            }
        }
    }

