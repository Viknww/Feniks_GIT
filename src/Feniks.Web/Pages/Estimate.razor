    // Вычисляемые свойства для сумм
    private decimal workCost => items.Where(i => i.Type == "P").Sum(i => i.Price * i.Quantity);
    private decimal materialCost => items.Where(i => i.Type == "M").Sum(i => i.Price * i.Quantity);
    private decimal machineryCost => items.Where(i => i.Type == "X").Sum(i => i.Price * i.Quantity);
    private decimal deliveryCost => items.Where(i => i.Type == "D").Sum(i => i.Price * i.Quantity);
    private decimal totalCost => items.Sum(i => i.Price * i.Quantity);

    private decimal customerWorkCost => items.Where(i => i.Type == "P").Sum(i => i.CustomerPrice * i.Quantity);
    private decimal customerMaterialCost => items.Where(i => i.Type == "M").Sum(i => i.CustomerPrice * i.Quantity);
    private decimal customerMachineryCost => items.Where(i => i.Type == "X").Sum(i => i.CustomerPrice * i.Quantity);
    private decimal customerDeliveryCost => items.Where(i => i.Type == "D").Sum(i => i.CustomerPrice * i.Quantity);
    private decimal customerTotal => items.Sum(i => i.CustomerPrice * i.Quantity);

    private decimal profitWork => customerWorkCost - workCost;
    private decimal profitMaterial => customerMaterialCost - materialCost;
    private decimal profitMachineryCost => customerMachineryCost - machineryCost;
    private decimal profitDelivery => customerDeliveryCost - deliveryCost;
    private decimal profitTotal => customerTotal - totalCost;

    private decimal selectedSum => items.Where(i => selectedItems.Contains(i.Id)).Sum(i => i.Price * i.Quantity);
    private decimal selectedCustomerSum => items.Where(i => selectedItems.Contains(i.Id)).Sum(i => i.CustomerPrice * i.Quantity);
    private decimal selectedProfit => selectedCustomerSum - selectedSum;

    private decimal GetStageTotal(int stageId)
    {
        var stageGroupIds = groups.Where(g => g.StageId == stageId).Select(g => g.Id).ToList();
        var groupedTotal = items.Where(i => i.GroupId.HasValue && stageGroupIds.Contains(i.GroupId.Value)).Sum(i => i.Price * i.Quantity);
        var ungroupedTotal = items.Where(i => !i.GroupId.HasValue && i.StageId == stageId).Sum(i => i.Price * i.Quantity);
        return groupedTotal + ungroupedTotal;
    }

    private decimal GetStageCustomerTotal(int stageId)
    {
        var stageGroupIds = groups.Where(g => g.StageId == stageId).Select(g => g.Id).ToList();
        var groupedTotal = items.Where(i => i.GroupId.HasValue && stageGroupIds.Contains(i.GroupId.Value)).Sum(i => i.CustomerPrice * i.Quantity);
        var ungroupedTotal = items.Where(i => !i.GroupId.HasValue && i.StageId == stageId).Sum(i => i.CustomerPrice * i.Quantity);
        return groupedTotal + ungroupedTotal;
    }

    private decimal GetStageProfit(int stageId) => GetStageCustomerTotal(stageId) - GetStageTotal(stageId);

    // Метод для безопасного форматирования чисел
    private string FormatNumber(decimal value)
    {
        try
        {
            if (value >= 1_000_000_000)
                return $"{(value / 1_000_000_000):F1} млрд";
            if (value >= 1_000_000)
                return $"{(value / 1_000_000):F1} млн";
            if (value >= 1_000)
                return $"{(value / 1_000):F1} тыс";
            return value.ToString("N0", System.Globalization.CultureInfo.InvariantCulture);
        }
        catch
        {
            return "0";
        }
    }

