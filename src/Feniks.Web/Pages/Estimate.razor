    private async Task CopySelected()
    {
        if (selectedItems.Count == 0) return;

        var itemsToCopy = items.Where(i => selectedItems.Contains(i.Id)).ToList();
        foreach (var item in itemsToCopy)
        {
            var newItem = new
            {
                EstimateId = Id,
                GroupId = item.GroupId,
                StageId = item.StageId,
                Name = $"{item.Name} (копия)",
                Unit = item.Unit,
                Quantity = item.Quantity,
                Price = item.Price,
                Markup = item.Markup,
                Type = item.Type,
                OrderIndex = items.Count,
                CustomerPrice = item.CustomerPrice
            };
            await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", newItem);
        }
        await LoadData();
        selectedItems.Clear();
        NotificationService.NotifyDataChanged();
    }

    private void ShowMoveToGroup()
    {
        if (selectedItems.Count > 0)
        {
            var firstItem = items.FirstOrDefault(i => selectedItems.Contains(i.Id));
            selectedStageIdForNewGroup = firstItem?.StageId ?? stages.FirstOrDefault()?.Id;
            
            showMoveModal = true;
            isCreatingNewGroup = false;
            newGroupName = "";
            moveToGroupId = null;
            StateHasChanged();
        }
    }

    private void CloseMoveModal()
    {
        showMoveModal = false;
        moveToGroupId = null;
        isCreatingNewGroup = false;
        newGroupName = "";
        StateHasChanged();
    }
    
    private void CancelNewGroup()
    {
        isCreatingNewGroup = false;
        newGroupName = "";
        moveToGroupId = null;
        StateHasChanged();
    }

    private async Task MoveToGroup()
    {
        if (moveToGroupId == null)
        {
            await JS.InvokeVoidAsync("alert", "Выберите группу");
            return;
        }

        if (moveToGroupId == -1)
        {
            isCreatingNewGroup = true;
            moveToGroupId = null;
            StateHasChanged();
            return;
        }

        var orders = selectedItems.Select((id, index) => new
        {
            id = id,
            orderIndex = index,
            groupId = moveToGroupId
        }).ToList();

        try
        {
            await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems/reorder", orders);
            await LoadData();
            selectedItems.Clear();
            CloseMoveModal();
            NotificationService.NotifyDataChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка перемещения: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
    }

    private async Task CreateNewGroupAndMove()
    {
        if (string.IsNullOrWhiteSpace(newGroupName))
        {
            await JS.InvokeVoidAsync("alert", "Введите название группы");
            return;
        }

        if (selectedStageIdForNewGroup == null)
        {
            await JS.InvokeVoidAsync("alert", "Не удалось определить этап для группы");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            var newGroup = new
            {
                StageId = selectedStageIdForNewGroup,
                Name = newGroupName,
                OrderIndex = groups.Count(g => g.StageId == selectedStageIdForNewGroup),
                IsExpanded = true
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItemGroups", newGroup);
            
            if (response.IsSuccessStatusCode)
            {
                var createdGroup = await response.Content.ReadFromJsonAsync<EstimateItemGroup>();
                if (createdGroup != null)
                {
                    groups.Add(createdGroup);
                    groupExpandedState[createdGroup.Id] = true;

                    var orders = selectedItems.Select((id, index) => new
                    {
                        id = id,
                        orderIndex = index,
                        groupId = createdGroup.Id
                    }).ToList();

                    await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems/reorder", orders);
                    
                    await LoadData();
                    selectedItems.Clear();
                    CloseMoveModal();
                    NotificationService.NotifyDataChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка создания группы: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            isCreatingNewGroup = false;
            StateHasChanged();
        }
    }

