    private async Task CreateNewGroupInAdd()
    {
        if (string.IsNullOrWhiteSpace(newGroupNameInAdd) || !newItem.StageId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Выберите этап и введите название группы");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            var newGroup = new
            {
                stageId = newItem.StageId.Value,
                name = newGroupNameInAdd,
                orderIndex = groups.Count(g => g.StageId == newItem.StageId.Value),
                isExpanded = true
            };

            Console.WriteLine($"Создание группы в диалоге добавления: {System.Text.Json.JsonSerializer.Serialize(newGroup)}");

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItemGroups", newGroup);
            
            if (response.IsSuccessStatusCode)
            {
                var createdGroup = await response.Content.ReadFromJsonAsync<EstimateItemGroup>();
                if (createdGroup != null)
                {
                    groups.Add(createdGroup);
                    newItem.GroupId = createdGroup.Id;
                    isCreatingNewGroupInAdd = false;
                    newGroupNameInAdd = "";
                    
                    await JS.InvokeVoidAsync("alert", $"✅ Группа '{createdGroup.Name}' создана");
                    StateHasChanged();
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка при создании группы: {error}");
                await JS.InvokeVoidAsync("alert", $"❌ Ошибка при создании группы: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка создания группы: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task AddItem()
    {
        // Проверяем, что название заполнено
        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            await JS.InvokeVoidAsync("alert", "Заполните наименование позиции");
            return;
        }

        // ВАЖНО: Проверяем, что StageId установлен
        if (!newItem.StageId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Ошибка: не выбран этап. Пожалуйста, закройте и откройте модальное окно заново.");
            Console.WriteLine("❌ Ошибка: newItem.StageId = null");
            return;
        }

        // Проверка на создание новой группы
        if (newItem.GroupId == -1)
        {
            isCreatingNewGroupInAdd = true;
            newItem.GroupId = null;
            StateHasChanged();
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            // Логируем отправляемые данные
            Console.WriteLine($"📤 Отправка данных в API:");
            Console.WriteLine($"   - EstimateId: {Id}");
            Console.WriteLine($"   - StageId: {newItem.StageId} (ОБЯЗАТЕЛЬНО)");
            Console.WriteLine($"   - GroupId: {newItem.GroupId}");
            Console.WriteLine($"   - Name: {newItem.Name}");
            Console.WriteLine($"   - Quantity: {newItem.Quantity}");
            Console.WriteLine($"   - Price: {newItem.Price}");
            Console.WriteLine($"   - Markup: {newItem.Markup}");

            var itemToAdd = new
            {
                EstimateId = Id,
                GroupId = newItem.GroupId,
                StageId = newItem.StageId,
                Name = newItem.Name,
                Unit = newItem.Unit ?? "шт",
                Quantity = newItem.Quantity,
                Price = newItem.Price,
                Markup = newItem.Markup,
                Type = newItem.Type ?? "P",
                OrderIndex = items.Count,
                CustomerPrice = newItem.Price * (1 + newItem.Markup / 100)
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", itemToAdd);
            
            if (response.IsSuccessStatusCode)
            {
                var createdItem = await response.Content.ReadFromJsonAsync<EstimateItem>();
                if (createdItem != null)
                {
                    Console.WriteLine($"✅ Позиция успешно создана с ID: {createdItem.Id}, StageId: {createdItem.StageId}");
                    items.Add(createdItem);
                }
                
                CloseAddDialog();
                await LoadData();
                await NotifyChanges();
                
                await JS.InvokeVoidAsync("alert", "✅ Позиция успешно добавлена!");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка API: {response.StatusCode} - {error}");
                await JS.InvokeVoidAsync("alert", $"Ошибка при добавлении: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Исключение: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

