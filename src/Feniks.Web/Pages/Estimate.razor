    private async Task AddStage()
    {
        try
        {
            isSaving = true;
            
            int nextOrderIndex = stages.Count;
            
            var newStage = new 
            { 
                EstimateId = Id, 
                Name = $"Этап {stages.Count + 1}", 
                Description = "",
                OrderIndex = nextOrderIndex, 
                IsExpanded = true 
            };
            
            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateStages", newStage);
            
            if (response.IsSuccessStatusCode)
            {
                var created = await response.Content.ReadFromJsonAsync<EstimateStage>();
                if (created != null)
                {
                    stages.Add(created);
                    stageExpandedState[created.Id] = true;
                    await NotifyChanges();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

