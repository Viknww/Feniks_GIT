    private async Task CreateGroupAndMove()
    {
        if (string.IsNullOrWhiteSpace(newGroupName))
        {
            await JS.InvokeVoidAsync("alert", "Введите название группы");
            return;
        }

        if (!selectedGroupStageId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Выберите этап для создания группы");
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            int targetStageId = selectedGroupStageId.Value;

            var newGroup = new
            {
                stageId = targetStageId,
                name = newGroupName,
                orderIndex = groups.Count(g => g.StageId == targetStageId),
                isExpanded = true
            };

            Console.WriteLine($"Создание группы в этапе {targetStageId}: {System.Text.Json.JsonSerializer.Serialize(newGroup)}");

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItemGroups", newGroup);
            
            if (response.IsSuccessStatusCode)
            {
                var createdGroup = await response.Content.ReadFromJsonAsync<EstimateItemGroup>();
                if (createdGroup != null)
                {
                    Console.WriteLine($"✅ Группа создана с ID: {createdGroup.Id}");
                    
                    var orders = selectedItems.Select((id, index) => new
                    {
                        id = id,
                        orderIndex = index,
                        groupId = createdGroup.Id
                    }).ToList();

                    var reorderResponse = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems/reorder", orders);
                    
                    if (reorderResponse.IsSuccessStatusCode)
                    {
                        await LoadData();
                        selectedItems.Clear();
                        CloseGroupModal();
                        await NotifyChanges();
                        
                        await JS.InvokeVoidAsync("alert", $"✅ Группа '{newGroupName}' создана, {selectedItems.Count} позиций перемещено");
                    }
                    else
                    {
                        var error = await reorderResponse.Content.ReadAsStringAsync();
                        Console.WriteLine($"❌ Ошибка перемещения: {error}");
                        await JS.InvokeVoidAsync("alert", $"Группа создана, но ошибка при перемещении: {reorderResponse.StatusCode}");
                    }
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка создания группы: {error}");
                await JS.InvokeVoidAsync("alert", $"Ошибка при создании группы: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка создания группы: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

