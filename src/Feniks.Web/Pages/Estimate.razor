    private async Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            await JS.InvokeVoidAsync("alert", "Заполните наименование позиции");
            return;
        }

        if (!newItem.StageId.HasValue)
        {
            await JS.InvokeVoidAsync("alert", "Ошибка: не выбран этап. Пожалуйста, закройте и откройте модальное окно заново.");
            Console.WriteLine("❌ Ошибка: newItem.StageId = null");
            return;
        }

        if (newItem.GroupId == -1)
        {
            isCreatingNewGroupInAdd = true;
            newItem.GroupId = null;
            StateHasChanged();
            return;
        }

        try
        {
            isSaving = true;
            StateHasChanged();

            Console.WriteLine($"📤 Отправка данных в API:");
            Console.WriteLine($"   - EstimateId: {Id}");
            Console.WriteLine($"   - StageId: {newItem.StageId}");
            Console.WriteLine($"   - GroupId: {newItem.GroupId}");
            Console.WriteLine($"   - Name: {newItem.Name}");
            Console.WriteLine($"   - Quantity: {newItem.Quantity}");
            Console.WriteLine($"   - Price: {newItem.Price}");
            Console.WriteLine($"   - Markup: {newItem.Markup}");

            var itemToAdd = new
            {
                EstimateId = Id,
                GroupId = newItem.GroupId,
                StageId = newItem.StageId,
                Name = newItem.Name,
                Unit = newItem.Unit ?? "шт",
                Quantity = newItem.Quantity,
                Price = newItem.Price,
                Markup = newItem.Markup,
                Type = newItem.Type ?? "P",
                OrderIndex = items.Count,
                CustomerPrice = newItem.Price * (1 + newItem.Markup / 100)
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/EstimateItems", itemToAdd);
            
            if (response.IsSuccessStatusCode)
            {
                var createdItem = await response.Content.ReadFromJsonAsync<EstimateItem>();
                if (createdItem != null)
                {
                    Console.WriteLine($"✅ Позиция успешно создана с ID: {createdItem.Id}, StageId: {createdItem.StageId}");
                    items.Add(createdItem);
                }
                
                CloseAddDialog();
                await LoadData();
                await NotifyChanges();
                
                await JS.InvokeVoidAsync("alert", "✅ Позиция успешно добавлена!");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"❌ Ошибка API: {response.StatusCode} - {error}");
                await JS.InvokeVoidAsync("alert", $"Ошибка при добавлении: {response.StatusCode}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Исключение: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

