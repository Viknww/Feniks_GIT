@page "/object/{id:int}"
@using Feniks.Shared.Models
@using SharedEstimate = Feniks.Shared.Models.Estimate
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container py-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка объекта...</p>
        </div>
    }
    else if (obj == null)
    {
        <div class="alert alert-danger">Объект не найден</div>
    }
    else
    {
        <!-- Заголовок объекта -->
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h2 class="fw-bold">@obj.Name</h2>
                <div class="d-flex gap-3 text-muted">
                    <span><i class="bi bi-person me-1"></i>@obj.Customer</span>
                    <span><i class="bi bi-geo-alt me-1"></i>@obj.Address</span>
                </div>
            </div>
            <button class="btn btn-outline-primary" @onclick="EditObject">
                <i class="bi bi-pencil me-1"></i>Редактировать
            </button>
        </div>

        <!-- Компактные финансовые показатели -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Количество смет</h6>
                                <h4 class="mb-0 fw-bold">@(estimates?.Count ?? 0)</h4>
                            </div>
                            <div class="bg-primary bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-files fs-4 text-primary"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Себестоимость</h6>
                                <h4 class="mb-0 fw-bold">@totalCost.ToString("N0") ₽</h4>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-calculator fs-4 text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Прибыль</h6>
                                <h4 class="mb-0 fw-bold" style="color: #b45f06;">@totalProfit.ToString("N0") ₽</h4>
                            </div>
                            <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-graph-up-arrow fs-4" style="color: #b45f06;"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Для заказчика</h6>
                                <h4 class="mb-0 fw-bold text-success">@totalCustomerPrice.ToString("N0") ₽</h4>
                            </div>
                            <div class="bg-success bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-currency-ruble fs-4 text-success"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Оплачено</h6>
                                <h4 class="mb-0 fw-bold text-info">@totalPaid.ToString("N0") ₽</h4>
                                <small class="text-muted">будет позже</small>
                            </div>
                            <div class="bg-info bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-check2-circle fs-4 text-info"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 bg-light">
                    <div class="card-body py-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="text-muted mb-1">Задолженность</h6>
                                <h4 class="mb-0 fw-bold text-danger">@totalDebt.ToString("N0") ₽</h4>
                                <small class="text-muted">будет позже</small>
                            </div>
                            <div class="bg-danger bg-opacity-10 p-3 rounded-circle">
                                <i class="bi bi-exclamation-triangle fs-4 text-danger"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Список смет объекта -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3">
                <div class="d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">Сметы объекта</h5>
                    <button class="btn btn-primary btn-sm" @onclick="AddNewEstimate">
                        <i class="bi bi-plus-circle me-1"></i>Новая смета
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                @if (estimates == null || !estimates.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-file-earmark-text fs-1 d-block mb-3"></i>
                        <p>У объекта нет смет</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="px-4 py-3">Название сметы</th>
                                    <th class="py-3">Статус</th>
                                    <th class="py-3 text-end">Себестоимость</th>
                                    <th class="py-3 text-end">Для заказчика</th>
                                    <th class="py-3 text-end">Прибыль</th>
                                    <th class="py-3 text-end">Дата</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var est in estimates)
                                {
                                    var profit = est.CustomerPrice - est.TotalCost;
                                    var profitPercent = est.TotalCost > 0 ? (profit / est.TotalCost * 100) : 0;
                                    <tr style="cursor: pointer;" @onclick="() => GoToEstimate(est.Id)" class="border-bottom">
                                        <td class="px-4 py-3 fw-medium">@est.Name</td>
                                        <td class="py-3"><span class="badge @GetStatusBadge(est.Status) px-3 py-2">@est.Status</span></td>
                                        <td class="py-3 text-end fw-medium">@est.TotalCost.ToString("N0") ₽</td>
                                        <td class="py-3 text-end text-success fw-bold">@est.CustomerPrice.ToString("N0") ₽</td>
                                        <td class="py-3 text-end" style="color: #b45f06;">
                                            <span class="fw-bold">@profit.ToString("N0") ₽</span>
                                            <small class="text-muted ms-1">(@profitPercent.ToString("F0")%)</small>
                                        </td>
                                        <td class="py-3 text-end text-muted">@est.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private bool isLoading = true;
    private ConstructionObject? obj;
    private List<SharedEstimate>? estimates;
    private decimal totalCost = 0;
    private decimal totalCustomerPrice = 0;
    private decimal totalProfit = 0;
    private decimal totalPaid = 0;
    private decimal totalDebt = 0;
    private int currentId;

    protected override async Task OnInitializedAsync()
    {
        currentId = Id;
        Console.WriteLine($"🔄 ObjectPage инициализирован с ID: {Id}");
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        if (currentId != Id)
        {
            currentId = Id;
            Console.WriteLine($"🔄 Параметр ID изменился на: {Id}");
            _ = LoadData();
        }
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            StateHasChanged();
            
            Console.WriteLine($"📥 Загрузка данных для объекта ID: {Id}");
            
            obj = await Http.GetFromJsonAsync<ConstructionObject>($"http://localhost:5050/api/ConstructionObjects/{Id}");
            
            if (obj != null)
            {
                var allEstimates = await Http.GetFromJsonAsync<List<SharedEstimate>>("http://localhost:5050/api/Estimates");
                if (allEstimates != null)
                {
                    estimates = allEstimates.Where(e => e.ConstructionObjectId == Id).ToList();
                    totalCost = estimates.Sum(e => e.TotalCost);
                    totalCustomerPrice = estimates.Sum(e => e.CustomerPrice);
                    totalProfit = totalCustomerPrice - totalCost;
                    
                    // Заглушки (позже будут браться из таблицы Payment)
                    totalPaid = totalCustomerPrice / 3;
                    totalDebt = totalCustomerPrice - totalPaid;
                }
                Console.WriteLine($"✅ Данные для объекта {Id} загружены");
            }
            else
            {
                Console.WriteLine($"❌ Объект {Id} не найден");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Черновик" => "bg-secondary",
        "В работе" => "bg-primary",
        "Согласование" => "bg-warning text-dark",
        "Утверждена" => "bg-success",
        "Завершена" => "bg-info",
        _ => "bg-light text-dark"
    };

    private void EditObject()
    {
        Navigation.NavigateTo($"/object/{Id}/edit");
    }

    private void AddNewEstimate()
    {
        Navigation.NavigateTo($"/estimate/new/{Id}");
    }

    private void GoToEstimate(int estimateId)
    {
        Navigation.NavigateTo($"/estimate/{estimateId}");
    }
}