@page "/objects"
@using Feniks.Shared.Models
@using SharedEstimate = Feniks.Shared.Models.Estimate
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Объекты строительства</h2>
        <button class="btn btn-primary" @onclick="CreateNewObject">
            <i class="bi bi-plus-circle me-1"></i>Новый объект
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка объектов...</p>
        </div>
    }
    else if (objects == null || !objects.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-building fs-1 d-block mb-3"></i>
            <p>Нет объектов строительства</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var obj in objects)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@obj.Name</h5>
                            <p class="card-text text-muted small">@obj.Customer</p>
                            <p class="card-text text-muted small">@obj.Address</p>
                            
                            <div class="d-flex justify-content-between mt-3">
                                <div class="text-start">
                                    <small class="text-muted d-block">Смет</small>
                                    <strong>@GetEstimateCount(obj.Id)</strong>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">Бюджет</small>
                                    <strong>@GetObjectBudget(obj).ToString("N0") ₽</strong>
                                </div>
                            </div>
                            
                            <div class="mt-3 d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewObject(obj.Id)">
                                    <i class="bi bi-eye"></i> Открыть
                                </button>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditObject(obj.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private List<ConstructionObject>? objects;
    private List<SharedEstimate>? allEstimates;
    private Dictionary<int, decimal> objectBudgets = new();
    private Dictionary<int, int> objectEstimateCounts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadObjects();
    }

    private async Task LoadObjects()
    {
        try
        {
            isLoading = true;
            
            // Загружаем все объекты
            objects = await Http.GetFromJsonAsync<List<ConstructionObject>>("http://localhost:5050/api/ConstructionObjects");
            
            // Загружаем все сметы
            allEstimates = await Http.GetFromJsonAsync<List<SharedEstimate>>("http://localhost:5050/api/Estimates");
            
            if (objects != null && allEstimates != null)
            {
                // Для каждого объекта вычисляем бюджет и количество смет
                foreach (var obj in objects)
                {
                    var objEstimates = allEstimates.Where(e => e.ConstructionObjectId == obj.Id);
                    objectBudgets[obj.Id] = objEstimates.Sum(e => e.TotalCost);
                    objectEstimateCounts[obj.Id] = objEstimates.Count();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private int GetEstimateCount(int objectId)
    {
        return objectEstimateCounts.ContainsKey(objectId) ? objectEstimateCounts[objectId] : 0;
    }

    private decimal GetObjectBudget(ConstructionObject obj)
    {
        return objectBudgets.ContainsKey(obj.Id) ? objectBudgets[obj.Id] : 0;
    }

    private void CreateNewObject()
    {
        Navigation.NavigateTo("/object/new");
    }

    private void ViewObject(int id)
    {
        Navigation.NavigateTo($"/object/{id}");
    }

    private void EditObject(int id)
    {
        Navigation.NavigateTo($"/object/{id}/edit");
    }
}