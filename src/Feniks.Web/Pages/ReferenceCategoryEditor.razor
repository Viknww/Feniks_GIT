@page "/reference-category/{id:int}/edit"
@page "/reference-category/new"
@using Feniks.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">@(isNewCategory ? "➕ Новая категория" : "✏️ Редактирование категории")</h4>
                </div>
                <div class="card-body">
                    <!-- Название категории -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Название категории *</label>
                        <input type="text" class="form-control" @bind="categoryName" 
                               placeholder="Например: Материалы" />
                    </div>

                    <!-- Описание -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание</label>
                        <textarea class="form-control" @bind="categoryDescription" rows="3" 
                                  placeholder="Описание категории"></textarea>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <!-- Кнопки -->
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button class="btn btn-secondary" @onclick="Cancel">Отмена</button>
                        <button class="btn btn-primary" @onclick="SaveCategory" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @(isNewCategory ? "Создать категорию" : "Сохранить")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }

    private bool isNewCategory => !Id.HasValue || Id == 0;
    private bool isSaving = false;
    private string errorMessage = "";

    private string categoryName = "";
    private string categoryDescription = "";

    protected override async Task OnInitializedAsync()
    {
        if (!isNewCategory)
        {
            await LoadCategory();
        }
    }

    private async Task LoadCategory()
    {
        try
        {
            var category = await Http.GetFromJsonAsync<ReferenceCategory>($"http://localhost:5050/api/ReferenceCategories/{Id}");
            if (category != null)
            {
                categoryName = category.Name;
                categoryDescription = category.Description ?? "";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Ошибка загрузки категории";
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(categoryName))
        {
            errorMessage = "Название категории обязательно";
            return;
        }

        try
        {
            isSaving = true;
            errorMessage = "";

            var category = new ReferenceCategory
            {
                Id = Id ?? 0,
                Name = categoryName,
                Description = string.IsNullOrWhiteSpace(categoryDescription) ? null : categoryDescription,
                CreatedAt = DateTime.Now
            };

            HttpResponseMessage response;
            if (isNewCategory)
            {
                response = await Http.PostAsJsonAsync("http://localhost:5050/api/ReferenceCategories", category);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"http://localhost:5050/api/ReferenceCategories/{Id}", category);
            }

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", isNewCategory ? "✅ Категория успешно создана!" : "✅ Категория успешно обновлена!");
                Navigation.NavigateTo("/references");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Ошибка сохранения: {response.StatusCode}";
                Console.WriteLine(error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/references");
    }
}