@page "/reference/{id:int}/edit"
@page "/reference/new/{categoryId:int}"
@using Feniks.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">@(isNewReference ? "➕ Новый справочник" : "✏️ Редактирование справочника")</h4>
                </div>
                <div class="card-body">
                    <!-- Название справочника -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Название справочника *</label>
                        <input type="text" class="form-control" @bind="referenceName" 
                               placeholder="Например: Кирпич" />
                    </div>

                    <!-- Категория -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Категория</label>
                        <select class="form-select" @bind="referenceCategoryId">
                            <option value="">Без категории</option>
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                    </div>

                    <!-- Статус -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Статус</label>
                        <select class="form-select" @bind="referenceStatus">
                            <option value="Черновик">Черновик</option>
                            <option value="В работе">В работе</option>
                            <option value="Утверждена">Утверждена</option>
                            <option value="Завершена">Завершена</option>
                        </select>
                    </div>

                    <!-- Описание -->
                    <div class="mb-3">
                        <label class="form-label fw-bold">Описание</label>
                        <textarea class="form-control" @bind="referenceDescription" rows="3" 
                                  placeholder="Описание справочника"></textarea>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <!-- Кнопки -->
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button class="btn btn-secondary" @onclick="Cancel">Отмена</button>
                        <button class="btn btn-primary" @onclick="SaveReference" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @(isNewReference ? "Создать справочник" : "Сохранить")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? Id { get; set; }
    [Parameter] public int? CategoryId { get; set; }

    private bool isNewReference => !Id.HasValue || Id == 0;
    private bool isSaving = false;
    private string errorMessage = "";

    private string referenceName = "";
    private string referenceDescription = "";
    private int? referenceCategoryId;
    private string referenceStatus = "Черновик";

    private List<ReferenceCategory> categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        
        if (CategoryId.HasValue)
        {
            referenceCategoryId = CategoryId.Value;
        }
        
        if (!isNewReference)
        {
            await LoadReference();
        }
    }

    private async Task LoadCategories()
    {
        try
        {
            categories = await Http.GetFromJsonAsync<List<ReferenceCategory>>("http://localhost:5050/api/ReferenceCategories") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки категорий: {ex.Message}");
        }
    }

    private async Task LoadReference()
    {
        try
        {
            var reference = await Http.GetFromJsonAsync<Reference>($"http://localhost:5050/api/RefCatalogs/{Id}");
            if (reference != null)
            {
                referenceName = reference.Name;
                referenceDescription = reference.Description ?? "";
                referenceCategoryId = reference.CategoryId;
                referenceStatus = reference.Status;
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Ошибка загрузки справочника";
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private async Task SaveReference()
    {
        if (string.IsNullOrWhiteSpace(referenceName))
        {
            errorMessage = "Название справочника обязательно";
            return;
        }

        try
        {
            isSaving = true;
            errorMessage = "";

            var reference = new Reference
            {
                Id = Id ?? 0,
                Name = referenceName,
                Description = string.IsNullOrWhiteSpace(referenceDescription) ? null : referenceDescription,
                CategoryId = referenceCategoryId,
                Status = referenceStatus,
                CreatedAt = DateTime.Now
            };

            HttpResponseMessage response;
            if (isNewReference)
            {
                response = await Http.PostAsJsonAsync("http://localhost:5050/api/RefCatalogs", reference);
            }
            else
            {
                response = await Http.PutAsJsonAsync($"http://localhost:5050/api/RefCatalogs/{Id}", reference);
            }

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", isNewReference ? "✅ Справочник успешно создан!" : "✅ Справочник успешно обновлен!");
                Navigation.NavigateTo("/references");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Ошибка сохранения: {response.StatusCode}";
                Console.WriteLine(error);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/references");
    }
}