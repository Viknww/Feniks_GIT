@page "/reference-item/{id:int}"
@using Feniks.Shared.Models
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<link href="css/reference.css" rel="stylesheet" />

<div class="reference-page">
    <!-- Хлебные крошки -->
    <div class="breadcrumbs mb-3">
        <a href="/">Главная</a> <span class="mx-2">›</span>
        <a href="/references">Справочники</a> <span class="mx-2">›</span>
        <span>@(item?.Name ?? "")</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка позиции...</p>
        </div>
    }
    else if (item == null)
    {
        <div class="alert alert-danger">
            Позиция не найдена
        </div>
    }
    else
    {
        <!-- Индикатор сохранения -->
        @if (isSaving)
        {
            <div class="position-fixed top-0 end-0 m-3 p-2 bg-success text-white rounded">
                <i class="bi bi-check-circle me-1"></i>Сохранено
            </div>
        }

        <!-- Заголовок позиции -->
        <div class="reference-header bg-white rounded-3 shadow-sm p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <h1 class="h3 mb-2">@item.Name</h1>
                    <div class="d-flex gap-4 text-muted flex-wrap">
                        <span><i class="bi bi-tag me-1"></i> Каталог: @catalogName</span>
                        <span><i class="bi bi-box-seam me-1"></i> Ед. изм.: @item.Unit</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-primary" @onclick="EditItem">
                        <i class="bi bi-pencil me-1"></i>Редактировать
                    </button>
                    <button class="btn btn-sm btn-outline-danger" @onclick="DeleteItem">
                        <i class="bi bi-trash me-1"></i>Удалить
                    </button>
                </div>
            </div>
        </div>

        <!-- Карточки стоимости -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-primary">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Себестоимость</h6>
                        <h3 class="mb-0 text-primary">@item.Price.ToString("N2") ₽</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-warning">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Наценка</h6>
                        <h3 class="mb-0 text-warning">@item.Markup.ToString("N1")%</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card shadow-sm border-success">
                    <div class="card-body">
                        <h6 class="text-muted mb-2">Цена для заказчика</h6>
                        <h3 class="mb-0 text-success">@item.CustomerPrice.ToString("N2") ₽</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Детальная информация -->
        <div class="row">
            <div class="col-md-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Информация</h6>
                    </div>
                    <div class="card-body">
                        <table class="table table-sm">
                            <tr>
                                <th style="width: 150px;">Округление:</th>
                                <td>@GetRoundingText(item.Rounding)</td>
                            </tr>
                            <tr>
                                <th>Дата создания:</th>
                                <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                            @if (item.UpdatedAt.HasValue)
                            {
                                <tr>
                                    <th>Дата изменения:</th>
                                    <td>@item.UpdatedAt.Value.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(item.Description))
            {
                <div class="col-md-6">
                    <div class="card shadow-sm">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Примечание</h6>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@item.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private ReferenceItem? item;
    private string catalogName = "";
    private bool isLoading = true;
    private bool isSaving = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        _ = LoadData();
    }

    public void Dispose()
    {
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            
            item = await Http.GetFromJsonAsync<ReferenceItem>($"http://localhost:5050/api/ReferenceItems/{Id}");
            
            if (item != null && item.ReferenceId.HasValue)
            {
                var catalog = await Http.GetFromJsonAsync<RefCatalog>($"http://localhost:5050/api/RefCatalogs/{item.ReferenceId.Value}");
                catalogName = catalog?.Name ?? "Без каталога";
            }
            else
            {
                catalogName = "Без каталога";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetRoundingText(RoundingType rounding)
    {
        return rounding switch
        {
            RoundingType.None => "Нет",
            RoundingType.Up => "Вверх",
            RoundingType.Down => "Вниз",
            RoundingType.Keep => "Не менять",
            _ => "Нет"
        };
    }

    private void EditItem()
    {
        Navigation.NavigateTo($"/reference-item/{Id}/edit");
    }

    private async Task DeleteItem()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Удалить позицию?"))
        {
            try
            {
                isSaving = true;
                await Http.DeleteAsync($"http://localhost:5050/api/ReferenceItems/{Id}");
                Navigation.NavigateTo("/references");
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
            }
            finally
            {
                isSaving = false;
            }
        }
    }
}