@page "/reference/{id:int}"
@using Feniks.Shared.Models
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<link href="css/reference.css" rel="stylesheet" />

<div class="reference-page">
    <!-- Хлебные крошки -->
    <div class="breadcrumbs mb-3">
        <a href="/">Главная</a> <span class="mx-2">›</span>
        <a href="/reference-category/@(reference?.CategoryId)">Категории</a> <span class="mx-2">›</span>
        <span>@(reference?.Name ?? "")</span>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3">Загрузка справочника...</p>
        </div>
    }
    else if (reference == null)
    {
        <div class="alert alert-danger">
            Справочник не найден
        </div>
    }
    else
    {
        <!-- Индикатор сохранения -->
        @if (isSaving)
        {
            <div class="position-fixed top-0 end-0 m-3 p-2 bg-success text-white rounded">
                <i class="bi bi-check-circle me-1"></i>Сохранено
            </div>
        }

        <!-- Заголовок справочника -->
        <div class="reference-header bg-white rounded-3 shadow-sm p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap">
                <div>
                    <h1 class="h3 mb-2">@reference.Name</h1>
                    <div class="d-flex gap-4 text-muted flex-wrap">
                        <span><i class="bi bi-tag me-1"></i> Категория: @categoryName</span>
                    </div>
                    <div class="d-flex gap-3 mt-2">
                        <span class="badge @GetStatusBadge(reference.Status)">@reference.Status</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ExportItems">Экспорт</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="EditReference">Редактировать</button>
                </div>
            </div>
        </div>

        <!-- Поиск по позициям -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Поиск по позициям..." 
                           @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-success" @onclick="ShowAddDialog">
                    <i class="bi bi-plus-circle me-1"></i>Добавить
                </button>
            </div>
        </div>

        <!-- Таблица позиций -->
        @if (!allItems.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-file-earmark-text fs-1 d-block mb-3"></i>
                <p>Нет позиций в справочнике</p>
                <button class="btn btn-outline-primary" @onclick="ShowAddDialog">
                    Добавить первую позицию
                </button>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px">
                                <input type="checkbox" @bind="selectAll" @onclick="ToggleSelectAll" />
                            </th>
                            <th>№</th>
                            <th>Наименование</th>
                            <th style="width: 80px">Ед. изм.</th>
                            <th style="width: 100px">Цена</th>
                            <th style="width: 80px">Наценка %</th>
                            <th style="width: 120px">Цена зак.</th>
                            <th>Примечание</th>
                            <th style="width: 80px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < filteredItems.Count; i++)
                        {
                            var item = filteredItems[i];
                            <tr class="@(selectedItems.Contains(item.Id) ? "table-primary" : "")">
                                <td>
                                    <input type="checkbox" @bind="item.Selected" @onclick="() => ToggleItemSelection(item)" />
                                </td>
                                <td>@(i + 1)</td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="item.Name" @bind:event="onchange" @onblur="() => UpdateItem(item)" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="item.Unit" @bind:event="onchange" @onblur="() => UpdateItem(item)" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm" @bind="item.Price" step="0.01" min="0" @bind:event="onchange" @onblur="() => OnPriceChanged(item)" />
                                </td>
                                <td>
                                    <input type="number" class="form-control form-control-sm" @bind="item.Markup" step="0.1" min="0" @bind:event="onchange" @onblur="() => OnMarkupChanged(item)" />
                                </td>
                                <td class="fw-bold text-success">
                                    <input type="number" class="form-control form-control-sm" @bind="item.CustomerPrice" step="0.01" min="0" @bind:event="onchange" @onblur="() => OnCustomerPriceChanged(item)" />
                                </td>
                                <td>
                                    <input type="text" class="form-control form-control-sm" @bind="item.Description" @bind:event="onchange" @onblur="() => UpdateItem(item)" />
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteItem(item.Id)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Нижний колонтитул с выбранными позициями -->
            if (selectedItems.Any())
            {
                <div class="card shadow-sm mt-4 position-sticky-bottom">
                    <div class="card-body bg-light">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                            <div>
                                <span class="fw-bold me-3">Выбрано позиций: @selectedItems.Count</span>
                                <span class="me-3">💰 Сумма: @selectedSum.ToString("N0") ₽</span>
                                <span class="text-success">📊 Для заказчика: @selectedCustomerSum.ToString("N0") ₽</span>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary" @onclick="CopySelected">
                                    <i class="bi bi-files me-1"></i>Копировать
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="DeleteSelected">
                                    <i class="bi bi-trash me-1"></i>Удалить
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>

<!-- Диалог добавления позиции -->
@if (showAddDialog)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">➕ Добавить позицию</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddDialog"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Наименование *</label>
                            <input type="text" class="form-control" @bind="newItem.Name" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Ед. изм.</label>
                            <input type="text" class="form-control" @bind="newItem.Unit" placeholder="шт" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Цена</label>
                            <input type="number" class="form-control" @bind="newItem.Price" step="0.01" min="0" @bind:event="onchange" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Наценка, %</label>
                            <input type="number" class="form-control" @bind="newItem.Markup" step="0.1" min="0" @bind:event="onchange" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Цена для заказчика</label>
                            <input type="number" class="form-control" @bind="newItem.CustomerPrice" step="0.01" min="0" readonly />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Округление</label>
                            <select class="form-select" @bind="newItem.Rounding">
                                <option value="0">Нет</option>
                                <option value="1">Вверх</option>
                                <option value="2">Вниз</option>
                                <option value="3">Не менять</option>
                            </select>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Примечание</label>
                            <textarea class="form-control" @bind="newItem.Description" rows="2"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseAddDialog">Отмена</button>
                    <button class="btn btn-primary" @onclick="AddItem">Добавить</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Reference? reference;
    private string categoryName = "";
    private bool isLoading = true;
    private bool isSaving = false;
    private List<ItemViewModel> allItems = new();
    private List<ItemViewModel> filteredItems = new();
    private HashSet<int> selectedItems = new();
    private string searchTerm = "";
    private bool selectAll = false;
    private bool showAddDialog = false;

    private class NewItem
    {
        public string Name { get; set; } = "";
        public string Unit { get; set; } = "шт";
        public decimal Price { get; set; } = 0;
        public decimal Markup { get; set; } = 0;
        public decimal CustomerPrice { get; set; } = 0;
        public RoundingType Rounding { get; set; } = RoundingType.None;
        public string? Description { get; set; }
    }

    private NewItem newItem = new();

    private class ItemViewModel : Feniks.Shared.Models.ReferenceItem
    {
        public bool Selected { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override void OnParametersSet()
    {
        _ = LoadData();
    }

    public void Dispose()
    {
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            
            reference = await Http.GetFromJsonAsync<Reference>($"http://localhost:5050/api/RefCatalogs/{Id}");

            if (reference != null)
            {
                if (reference.CategoryId.HasValue)
                {
                    var category = await Http.GetFromJsonAsync<ReferenceCategory>($"http://localhost:5050/api/ReferenceCategories/{reference.CategoryId.Value}");
                    categoryName = category?.Name ?? "Без категории";
                }

                var items = await Http.GetFromJsonAsync<List<Feniks.Shared.Models.ReferenceItem>>($"http://localhost:5050/api/ReferenceItems?referenceId={Id}") ?? new();
                
                allItems = items.Select(i => new ItemViewModel
                {
                    Id = i.Id,
                    ReferenceId = i.ReferenceId,
                    Name = i.Name,
                    Unit = i.Unit,
                    Price = i.Price,
                    Markup = i.Markup,
                    Rounding = i.Rounding,
                    Description = i.Description,
                    CustomerPrice = i.CustomerPrice
                }).ToList();
                
                filteredItems = allItems;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetStatusBadge(string status) => status switch
    {
        "Черновик" => "bg-secondary",
        "В работе" => "bg-primary",
        "Завершена" => "bg-success",
        _ => "bg-info"
    };

    private void FilterItems()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
        {
            filteredItems = allItems;
        }
        else
        {
            filteredItems = allItems
                .Where(i => i.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                           (i.Description != null && i.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                .ToList();
        }
        StateHasChanged();
    }

    private void ToggleSelectAll()
    {
        foreach (var item in filteredItems)
        {
            item.Selected = selectAll;
        }
        UpdateSelectedItems();
    }

    private void ToggleItemSelection(ItemViewModel item)
    {
        item.Selected = !item.Selected;
        UpdateSelectedItems();
    }

    private void UpdateSelectedItems()
    {
        selectedItems = new HashSet<int>(filteredItems.Where(i => i.Selected).Select(i => i.Id));
        selectAll = filteredItems.All(i => i.Selected) && filteredItems.Any();
    }

    private void ShowAddDialog()
    {
        newItem = new NewItem();
        showAddDialog = true;
    }

    private void CloseAddDialog()
    {
        showAddDialog = false;
        newItem = new NewItem();
    }

    private void OnPriceChanged(ItemViewModel item)
    {
        item.CustomerPrice = item.Price * (1 + item.Markup / 100);
        _ = UpdateItem(item);
    }

    private void OnMarkupChanged(ItemViewModel item)
    {
        item.CustomerPrice = item.Price * (1 + item.Markup / 100);
        _ = UpdateItem(item);
    }

    private void OnCustomerPriceChanged(ItemViewModel item)
    {
        if (item.Price > 0)
        {
            item.Markup = ((item.CustomerPrice - item.Price) / item.Price) * 100;
        }
        _ = UpdateItem(item);
    }

    private async Task UpdateItem(ItemViewModel item)
    {
        try
        {
            isSaving = true;

            var update = new
            {
                item.Id,
                item.Name,
                item.Unit,
                item.Price,
                item.Markup,
                item.Rounding,
                item.Description,
                CustomerPrice = item.CustomerPrice,
                ReferenceId = item.ReferenceId,
                Quantity = 1
            };

            await Http.PutAsJsonAsync($"http://localhost:5050/api/ReferenceItems/{item.Id}", update);

            isSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка обновления: {ex.Message}");
            isSaving = false;
        }
    }

    private async Task AddItem()
    {
        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            await JS.InvokeVoidAsync("alert", "Заполните наименование");
            return;
        }

        try
        {
            isSaving = true;
            
            // Пересчитываем цену для заказчика
            newItem.CustomerPrice = newItem.Price * (1 + newItem.Markup / 100);
            
            var itemToAdd = new
            {
                ReferenceId = Id,
                Name = newItem.Name,
                Unit = newItem.Unit,
                Price = newItem.Price,
                Markup = newItem.Markup,
                Rounding = newItem.Rounding,
                Description = newItem.Description,
                CustomerPrice = newItem.CustomerPrice,
                Quantity = 1,
                OrderIndex = allItems.Count
            };

            var response = await Http.PostAsJsonAsync("http://localhost:5050/api/ReferenceItems", itemToAdd);
            
            if (response.IsSuccessStatusCode)
            {
                await LoadData();
                CloseAddDialog();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Ошибка: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteItem(int itemId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Удалить позицию?"))
        {
            await Http.DeleteAsync($"http://localhost:5050/api/ReferenceItems/{itemId}");
            await LoadData();
            selectedItems.Remove(itemId);
        }
    }

    private async Task DeleteSelected()
    {
        if (!selectedItems.Any()) return;
        
        if (await JS.InvokeAsync<bool>("confirm", $"Удалить {selectedItems.Count} позиций?"))
        {
            foreach (var id in selectedItems.ToList())
            {
                await Http.DeleteAsync($"http://localhost:5050/api/ReferenceItems/{id}");
            }
            await LoadData();
            selectedItems.Clear();
        }
    }

    private void CopySelected()
    {
        // TODO: Реализовать копирование
    }

    private void ExportItems()
    {
        // TODO: Реализовать экспорт
    }

    private void EditReference()
    {
        Navigation.NavigateTo($"/reference/{Id}/edit");
    }

    private decimal selectedSum => allItems.Where(i => selectedItems.Contains(i.Id)).Sum(i => i.Price);
    private decimal selectedCustomerSum => allItems.Where(i => selectedItems.Contains(i.Id)).Sum(i => i.CustomerPrice);
}